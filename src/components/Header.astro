---
const path = new URL(Astro.request.url).pathname;
const links = [
  { href: '/chi-siamo', label: 'Chi siamo' },
  { href: '/servizi', label: 'Servizi' },
  { href: '/dove-operiamo', label: 'Dove operiamo' },
  { href: '/referenze', label: 'Referenze' },
  { href: '/contatti', label: 'Contatti' },
];
---
<header>
  <div class="nav">
    <a href="/" class="brand">
      <img src="/images/tecnoconsult-icon.png" alt="Tecno Consult Srl" />
      <span class="brand-word">TECNO<span>CONSULT</span></span>
    </a>
    <input type="checkbox" id="nav-toggle" class="nav-toggle-input" />
    <ul class="nav-links">
      {links.map((link) => (
        <li><a href={link.href} aria-current={path === link.href ? 'page' : undefined}>{link.label}</a></li>
      ))}
      <li class="nav-tel-mobile">
        <a href="tel:+39042151200">📞 0421 51200</a>
      </li>
    </ul>
    <a class="nav-tel" href="tel:+39042151200">0421 51200</a>
    <label for="nav-toggle" class="nav-toggle" aria-label="Apri menu">
      <span></span><span></span><span></span>
    </label>
  </div>
</header>
