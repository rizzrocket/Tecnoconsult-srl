---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="Dove operiamo — Tecno Consult Srl"
  description="Tecno Consult opera in Veneto e Friuli Venezia Giulia: 8 province, grossisti, installatori, tecnici e progettisti."
>

<div class="wrap banner-image-wrap reveal">
  <img class="banner-image" src="/images/stock-cantiere.jpg" alt="Mezzo da cantiere sul territorio" loading="lazy" />
</div>

<!-- ============ DOVE OPERIAMO ============ -->
<section>
  <div class="wrap dove">
    <div class="reveal">
      <p class="eyebrow" style="margin-bottom:16px;">Dove operiamo</p>
      <p style="line-height:1.7;">Operiamo nel mercato idro-termo-sanitario, condizionamento, trattamento aria e acqua ed energie alternative — settori civile, industriale, terziario, commerciale, navale, alberghiero e termale.</p>
      <ul class="dove-list">
        <li><b>8</b> province tra Veneto e FVG</li>
        <li><b>Grossisti</b> e rivenditori</li>
        <li><b>Installatori</b>, tecnici e progettisti</li>
      </ul>
    </div>
    <div class="reveal" style="display:flex; justify-content:center;">
      <svg width="300" height="300" viewBox="0 0 300 300" fill="none">
        <!-- coverage rings centered on San Donà di Piave -->
        <circle cx="155" cy="150" r="125" stroke="#2d5563" stroke-width="1" stroke-dasharray="3 5" opacity="0.3"/>
        <circle cx="155" cy="150" r="88" stroke="#2d5563" stroke-width="1" stroke-dasharray="3 5" opacity="0.4"/>
        <circle cx="155" cy="150" r="50" stroke="#2d5563" stroke-width="1" stroke-dasharray="3 5" opacity="0.5"/>
        <!-- compass ticks -->
        <g stroke="#46565c" stroke-width="1.2" opacity="0.6">
          <line x1="155" y1="17" x2="155" y2="27"/>
          <line x1="155" y1="273" x2="155" y2="283"/>
          <line x1="22" y1="150" x2="32" y2="150"/>
          <line x1="278" y1="150" x2="288" y2="150"/>
        </g>
        <!-- regional split: Veneto (left/sotto) vs Friuli Venezia Giulia (destra/sopra) -->
        <line x1="60" y1="255" x2="245" y2="55" stroke="#2d5563" stroke-width="1" stroke-dasharray="2 4" opacity="0.45"/>
        <text x="78" y="215" font-family="IBM Plex Mono" font-size="11" font-weight="600" fill="#2d5563">VENETO</text>
        <text x="178" y="92" font-family="IBM Plex Mono" font-size="9.5" font-weight="600" fill="#2d5563">FRIULI</text>
        <text x="178" y="104" font-family="IBM Plex Mono" font-size="9.5" font-weight="600" fill="#2d5563">VENEZIA GIULIA</text>
        <!-- pin: San Donà di Piave -->
        <circle cx="155" cy="150" r="9" fill="none" stroke="#c1632b" stroke-width="1.5"/>
        <circle cx="155" cy="150" r="4" fill="#c1632b"/>
        <text x="155" y="178" text-anchor="middle" font-family="IBM Plex Mono" font-size="10" font-weight="600" fill="#16242a">SAN DONÀ DI PIAVE</text>
      </svg>
    </div>
  </div>
</section>

</Layout>
