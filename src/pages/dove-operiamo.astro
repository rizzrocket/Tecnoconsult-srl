---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="Dove operiamo — Tecno Consult Srl"
  description="Tecno Consult opera in Veneto e Friuli Venezia Giulia: 8 province, grossisti, installatori, tecnici e progettisti."
>

<!-- ============ DOVE OPERIAMO ============ -->
<section style="padding-top:46px;">
  <div class="wrap dove">
    <div class="reveal">
      <p class="eyebrow" style="margin-bottom:16px;">Dove operiamo</p>
      <p style="line-height:1.7;">Operiamo nel mercato idro-termo-sanitario, condizionamento, trattamento aria e acqua ed energie alternative — settori civile, industriale, terziario, commerciale, navale, alberghiero e termale.</p>
      <ul class="dove-list">
        <li><b>8</b> province tra Veneto e FVG</li>
        <li><b>Grossisti</b> e rivenditori</li>
        <li><b>Installatori</b>, tecnici e progettisti</li>
      </ul>
    </div>
    <div class="reveal" style="display:flex; justify-content:center;">
      <svg width="280" height="280" viewBox="0 0 280 280" fill="none">
        <g opacity="0.4">
          <path d="M0,70 H280 M0,140 H280 M0,210 H280" stroke="#2d5563" stroke-width="0.6"/>
          <path d="M70,0 V280 M140,0 V280 M210,0 V280" stroke="#2d5563" stroke-width="0.6"/>
        </g>
        <path d="M90,60 L150,50 L200,90 L210,150 L180,210 L120,225 L75,180 L60,110 Z" fill="#2d5563" opacity="0.12" stroke="#2d5563" stroke-width="2"/>
        <circle cx="150" cy="130" r="6" fill="#c1632b"/>
        <text x="150" y="115" text-anchor="middle" font-family="IBM Plex Mono" font-size="10" fill="#16242a">SAN DONÀ DI PIAVE</text>
      </svg>
    </div>
  </div>
</section>

</Layout>
