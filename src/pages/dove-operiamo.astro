<script>
  function initCoverageMap() {
    const svg = document.getElementById('coverage-svg');
    const wrap = document.getElementById('coverage-map-wrap');
    const tooltip = document.getElementById('coverage-tooltip');
    if (!svg || !wrap || !tooltip) return;

    const titleEl = tooltip.querySelector<HTMLElement>('.ct-title');
    const brandsEl = tooltip.querySelector<HTMLElement>('.ct-brands');
    if (!titleEl || !brandsEl) return;

    const BRAND_NAMES: Record<string, string> = { aquatechnik: 'Aquatechnik', radiant: 'Radiant', gda: 'GDA', itap: 'Itap' };
    const BRAND_ICONS: Record<string, string> = {
      aquatechnik: '/images/brands/aquatechnik.png',
      radiant: '/images/brands/radiant.svg',
      gda: '/images/brands/gda.jpg',
      itap: '/images/brands/itap.jpg',
    };

    let activePath: SVGPathElement | null = null;
    let lastPointerType = 'mouse';

    function renderTooltip(path: SVGPathElement) {
      const titleNode = path.querySelector('title');
      titleEl!.textContent = titleNode ? titleNode.textContent : '';
      const marchi = (path.dataset.marchi || '').split(',').map((s) => s.trim()).filter(Boolean);
      brandsEl!.innerHTML = '';
      if (!marchi.length) {
        brandsEl!.classList.add('ct-empty');
        brandsEl!.textContent = 'Nessun marchio attivo';
      } else {
        brandsEl!.classList.remove('ct-empty');
        marchi.forEach((slug) => {
          const item = document.createElement('div');
          item.className = 'ct-brand';
          const img = document.createElement('img');
          img.src = BRAND_ICONS[slug] || '';
          img.alt = BRAND_NAMES[slug] || slug;
          const span = document.createElement('span');
          span.textContent = BRAND_NAMES[slug] || slug;
          item.appendChild(img);
          item.appendChild(span);
          brandsEl!.appendChild(item);
        });
      }
    }

    function positionTooltip(clientX: number, clientY: number) {
      const rect = wrap!.getBoundingClientRect();
      let x = clientX - rect.left + 14;
      let y = clientY - rect.top + 14;
      const maxX = rect.width - tooltip!.offsetWidth - 8;
      const maxY = rect.height - tooltip!.offsetHeight - 8;
      x = Math.max(8, Math.min(x, maxX));
      y = Math.max(8, Math.min(y, maxY));
      tooltip!.style.left = x + 'px';
      tooltip!.style.top = y + 'px';
    }

    function show(path: SVGPathElement, clientX: number, clientY: number) {
      activePath = path;
      renderTooltip(path);
      tooltip!.hidden = false;
      positionTooltip(clientX, clientY);
      path.classList.add('is-active');
    }

    function hide() {
      if (activePath) activePath.classList.remove('is-active');
      activePath = null;
      tooltip!.hidden = true;
    }

    const paths = Array.from(svg.querySelectorAll<SVGPathElement>('path[data-code]'));

    svg.addEventListener('pointerdown', (e: PointerEvent) => {
      lastPointerType = e.pointerType;
    }, true);

    paths.forEach((path) => {
      path.addEventListener('pointerenter', (e: PointerEvent) => {
        if (e.pointerType === 'touch') return;
        show(path, e.clientX, e.clientY);
      });
      path.addEventListener('pointermove', (e: PointerEvent) => {
        if (e.pointerType === 'touch') return;
        if (activePath === path) positionTooltip(e.clientX, e.clientY);
      });
      path.addEventListener('pointerleave', (e: PointerEvent) => {
        if (e.pointerType === 'touch') return;
        hide();
      });
      path.addEventListener('click', (e: MouseEvent) => {
        if (lastPointerType !== 'touch') return;
        e.stopPropagation();
        if (activePath === path) {
          hide();
        } else {
          show(path, e.clientX, e.clientY);
        }
      });
    });

    document.addEventListener('click', (e) => {
      if (lastPointerType === 'touch' && activePath && !svg.contains(e.target as Node)) {
        hide();
      }
    });
  }
  document.addEventListener('astro:page-load', initCoverageMap);
</script>

