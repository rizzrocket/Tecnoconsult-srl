---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="Contatti — Tecno Consult Srl"
  description="Tecno Consult Srl, Via Barcis 2, 30027 San Donà di Piave (VE). Tel. 0421 51200, info@tecnoconsult-srl.it."
>

<!-- ============ CONTATTI ============ -->
<section style="padding-top:46px;">
  <div class="wrap">
    <div class="contatti reveal">
      <div>
        <p class="eyebrow" style="color:#7fa3ad;">Contatti</p>
        <h2 style="margin-top:8px;">Come raggiungerci</h2>
        <p class="lead">Via Barcis 2, 30027 San Donà di Piave (VE)</p>
        <div class="cta-row" style="margin-top:24px;">
          <a class="btn btn-primary" href="mailto:info@tecnoconsult-srl.it">Scrivi a info@tecnoconsult-srl.it</a>
        </div>
      </div>
      <div>
        <div class="contact-list">
          <a href="tel:+39042151200">Tel. 0421 51200</a>
          <span>Fax 0421 221082</span>
          <a href="mailto:info@tecnoconsult-srl.it">info@tecnoconsult-srl.it</a>
          <a href="https://www.facebook.com/tecnoconsultsrl" target="_blank" rel="noopener">facebook.com/tecnoconsultsrl</a>
        </div>
        <p class="hours">Lun–Ven 8:00–12:30 (telefono ed email) · 14:30–18:30 (solo email)</p>
      </div>
    </div>
  </div>
</section>

</Layout>
