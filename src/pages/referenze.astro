---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="Referenze — Tecno Consult Srl"
  description="Hotellerie, sanità ed enti pubblici, industria e residenziale: le referenze di Tecno Consult in Veneto e Friuli Venezia Giulia."
>

<section style="padding-top:46px; padding-bottom:20px;">
  <div class="wrap">
    <p class="eyebrow">Referenze</p>
    <p style="margin-top:8px; max-width:560px; color:var(--ink-soft); line-height:1.6;">Alcune delle realtà che nel tempo si sono affidate a Tecno Consult per i loro impianti idro-termo-sanitari.</p>
  </div>
</section>

<section class="ref-block ref-block--hotellerie">
  <div class="wrap">
    <div class="ref-section-header reveal">
      <span class="ref-section-cat">Hotellerie &amp; Ricettivo</span>
    </div>
    <div class="ref-name-grid reveal">
      <span class="ref-name-chip">Grand Hotel Excelsior — Lido di Venezia</span>
      <span class="ref-name-chip">Hotel Allmar — Jesolo</span>
      <span class="ref-name-chip">Falkensteiner Aparthotel — Jesolo</span>
      <span class="ref-name-chip">Hotel Napoleon — Jesolo</span>
      <span class="ref-name-chip">Hotel Nettuno — Jesolo</span>
      <span class="ref-name-chip">Hotel Caorle — Caorle (VE)</span>
      <span class="ref-name-chip">Camping Union Lido — Cavallino (VE)</span>
      <span class="ref-name-chip">Hotel a Lignano Prata</span>
      <span class="ref-name-chip">Grand Hotel Victoria — Abano Terme</span>
      <span class="ref-name-chip">Hotel Orologio — Venezia</span>
      <span class="ref-name-chip">Hotel Rosa Salva — Venezia</span>
      <span class="ref-name-chip">Hotel a Murano — Venezia</span>
      <span class="ref-name-chip">Hotel Europa Regina</span>
      <span class="ref-name-chip">Hotel Carnia — Carnia (UD)</span>
    </div>
  </div>
</section>

<section class="ref-block ref-block--sanita">
  <div class="wrap">
    <div class="ref-section-header reveal">
      <span class="ref-section-cat">Sanità &amp; Enti pubblici</span>
    </div>
    <div class="ref-name-grid reveal">
      <span class="ref-name-chip">Ospedale Civile di Cividale</span>
      <span class="ref-name-chip">Ospedale Borgo Trento — Verona</span>
      <span class="ref-name-chip">Capitaneria di Porto — Trieste</span>
      <span class="ref-name-chip">Guardia di Finanza FVG</span>
      <span class="ref-name-chip">Scuole di Fagagna</span>
    </div>
  </div>
</section>

<section class="ref-block ref-block--industria">
  <div class="wrap">
    <div class="ref-section-header reveal">
      <span class="ref-section-cat">Industria &amp; Residenziale</span>
    </div>
    <div class="ref-name-grid reveal">
      <span class="ref-name-chip">Magazzini Arredo 3 — Scorzè (VE)</span>
      <span class="ref-name-chip">Etigraf — Portogruaro (VE)</span>
      <span class="ref-name-chip">Concessionaria Opel e Land Rover — Conegliano</span>
      <span class="ref-name-chip">Stratex Bodino — Sutrio (UD)</span>
      <span class="ref-name-chip">Complesso residenziale — Fagagna (UD)</span>
      <span class="ref-name-chip">Complesso residenziale — Treviso</span>
      <span class="ref-name-chip">Complesso residenziale Eraclea — Eraclea (VE)</span>
      <span class="ref-name-chip">Complesso residenziale — Bibione (VE)</span>
      <span class="ref-name-chip">Complesso polifunzionale — Udine</span>
    </div>
  </div>
</section>

</Layout>
