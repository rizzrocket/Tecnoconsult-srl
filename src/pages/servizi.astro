---
<Layout
  title="Servizi — Tecno Consult Srl"
  description="Sette aree di servizio, un'unica squadra che segue il prodotto dalla vendita all'assistenza in cantiere."
>

<!-- ============ SERVIZI ============ -->
<section>
  <div class="wrap">
    <div class="section-head reveal">
      <p class="eyebrow">Servizi</p>
      <p>Sette aree di servizio, un'unica squadra che segue il prodotto in tutte le sue fasi.</p>
    </div>

    <div class="servizi-flex" id="servizi-flex">
      {servizi.map((s) => (
        <div
          class="servizio-card reveal"
          id={s.id}
          role="button"
          tabindex="0"
          aria-expanded="false"
          data-titolo={s.titolo}
          data-completo={s.completo}
        >
          <svg width="30" height="30" viewBox="0 0 30 30" set:html={s.icona} />
          <h3>{s.titolo}</h3>
          <p>{s.breve}</p>
          <span class="card-cue">Leggi tutto</span>
        </div>
      ))}
    </div>

    <div class="servizio-panel" id="servizio-panel" hidden>
      <div class="panel-inner">
        <div class="panel-text">
          <h3 id="panel-titolo"></h3>
          <p id="panel-completo"></p>
        </div>
        <div class="panel-photo">
          <div class="photo-ph" aria-hidden="true">
            <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="5" width="18" height="14" rx="2"/><circle cx="8.5" cy="10" r="1.8"/><path d="M21 16l-5-5L5 19" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Foto servizio in arrivo
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  function initServizi() {
    const grid = document.getElementById('servizi-flex');
    const panel = document.getElementById('servizio-panel');
    if (!grid || !panel) return;

    const titoloEl = document.getElementById('panel-titolo');
    const completoEl = document.getElementById('panel-completo');
    const cards = Array.from(grid.querySelectorAll<HTMLElement>('.servizio-card'));
    let current: HTMLElement | null = null;

    function closePanel() {
      panel.hidden = true;
      cards.forEach((c) => {
        c.classList.remove('is-open');
        c.setAttribute('aria-expanded', 'false');
      });
      current = null;
    }

    function openPanel(card: HTMLElement) {
      if (current === card) {
        closePanel();
        return;
      }
      cards.forEach((c) => {
        c.classList.remove('is-open');
        c.setAttribute('aria-expanded', 'false');
      });
      titoloEl!.textContent = card.dataset.titolo || '';
      completoEl!.textContent = card.dataset.completo || '';
      panel.hidden = false;
      card.classList.add('is-open');
      card.setAttribute('aria-expanded', 'true');
      current = card;
    }

    cards.forEach((card) => {
      card.addEventListener('click', () => openPanel(card));
      card.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          openPanel(card);
        }
      });
    });

    // Flash highlight della card corrispondente all'hash (#slug).
    // L'hash può non essere ancora applicato al momento di astro:page-load
    // (navigazione con View Transitions), quindi rileggiamo dopo un tick.
    let flashed = false;
    function flashFromHash() {
      if (flashed) return;
      const hash = window.location.hash.replace('#', '');
      if (!hash) return;
      const target = document.getElementById(hash);
      if (target && target.classList.contains('servizio-card')) {
        flashed = true;
        target.scrollIntoView({ behavior: 'smooth', block: 'center' });
        target.classList.add('flash');
        setTimeout(() => target.classList.remove('flash'), 2000);
      }
    }
    // L'hash con View Transitions può essere applicato dopo page-load:
    // riproviamo per una breve finestra finché non lo troviamo.
    [0, 100, 250, 500].forEach((d) => setTimeout(flashFromHash, d));
    window.addEventListener('hashchange', flashFromHash, { once: true });
  }
  document.addEventListener('astro:page-load', initServizi);
</script>

</Layout>
