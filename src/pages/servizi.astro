---
<Layout
  title="Servizi — Tecno Consult Srl"
  description="Sette aree di servizio, un'unica squadra che segue il prodotto dalla vendita all'assistenza in cantiere."
>

<!-- ============ SERVIZI — INTRO BANNER ============ -->
<section class="section--intro">
  <div class="wrap">
    <div class="split split--wide-text split--reverse reveal">
      <div>
        <h2 class="sec-title">Servizi</h2>
        <p style="font-size:1.06rem; line-height:1.7;">Sette aree di servizio, un'unica squadra che segue il prodotto in tutte le sue fasi: dalla vendita e la preventivazione all'assistenza in cantiere, fino alla formazione nel nostro Centro Didattico.</p>
        <p style="margin-top:14px; font-size:0.9rem; color:var(--ink-soft); line-height:1.7;">Tocca una card per leggere il dettaglio del servizio.</p>
      </div>
      <figure class="split-figure split-figure--framed split-media">
        <img src="/images/sede/sede-formazione.jpg" alt="Aula del Centro Didattico Formativo Tecno Consult allestita per un corso" loading="lazy" />
      </figure>
    </div>
  </div>
</section>

<!-- ============ SERVIZI — GRIGLIA ============ -->
<section class="section--tint">
  <div class="wrap">
    <div class="servizi-flex" id="servizi-flex">
      {servizi.map((s) => (
        <div
          class="servizio-card reveal"
          id={s.id}
          role="button"
          tabindex="0"
          aria-haspopup="dialog"
          data-titolo={s.titolo}
          data-completo={s.completo}
        >
          <svg width="30" height="30" viewBox="0 0 30 30" set:html={s.icona} />
          <h3>{s.titolo}</h3>
          <p>{s.breve}</p>
          <span class="card-cue">Leggi tutto</span>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ============ FORMAZIONE ============ -->
<section id="formazione" class="section--surface">
  <div class="wrap">
    <div class="split split--wide-media reveal">
      <figure class="split-figure split-figure--framed split-media">
        <img src="/images/formazione/mauro-banco.jpg" alt="Mauro Scarabel spiega al banco demo durante un corso nel Centro Didattico Formativo" loading="lazy" />
        <figcaption>Giornata al banco · Centro Didattico Formativo</figcaption>
      </figure>
      <div>
        <h2 class="sec-title">Formazione</h2>
        <p style="line-height:1.7;">Nel Centro Didattico Formativo di oltre 200 m² organizziamo corsi, presentazioni e webinar per installatori, tecnici, progettisti e centri assistenza, sui prodotti delle aziende rappresentate, sulle normative e sulle applicazioni.</p>
        <p style="margin-top:14px; line-height:1.7;">Accanto alla parte teorica — con proiezione e documentazione tecnica — mettiamo a disposizione un'area dimostrativa per le giornate al banco e l'affiancamento pratico, così che ogni professionista possa vedere, provare e installare correttamente i prodotti.</p>
        <ul class="plus-list" style="margin-top:22px;">
          <li>Corsi, presentazioni e webinar</li>
          <li>Giornate al banco e area dimostrativa</li>
          <li>Affiancamento pratico in cantiere</li>
          <li>Ricerca e accreditamento dei centri assistenza</li>
        </ul>
      </div>
    </div>
  </div>
</section>

<div class="servizio-modal-overlay" id="servizio-modal-overlay">
  <div
    class="servizio-modal"
    id="servizio-modal"
    role="dialog"
    aria-modal="true"
    aria-labelledby="servizio-modal-titolo"
    tabindex="-1"
  >
    <button type="button" class="servizio-modal-close" id="servizio-modal-close" aria-label="Chiudi">
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M2,2 L16,16 M16,2 L2,16"/></svg>
    </button>
    <h3 id="servizio-modal-titolo"></h3>
    <p id="servizio-modal-completo"></p>
  </div>
</div>

<script>
  function initServizi() {
    const grid = document.getElementById('servizi-flex');
    const overlay = document.getElementById('servizio-modal-overlay');
    const modal = document.getElementById('servizio-modal');
    const closeBtn = document.getElementById('servizio-modal-close');
    const titoloEl = document.getElementById('servizio-modal-titolo');
    const completoEl = document.getElementById('servizio-modal-completo');
    if (!grid || !overlay || !modal || !closeBtn || !titoloEl || !completoEl) return;

    const cards = Array.from(grid.querySelectorAll<HTMLElement>('.servizio-card'));
    let lastTrigger: HTMLElement | null = null;

    function getFocusable(): HTMLElement[] {
      return Array.from(
        modal!.querySelectorAll<HTMLElement>(
          'a[href], button:not([disabled]), textarea, input, select, [tabindex]:not([tabindex="-1"])'
        )
      );
    }

    function onKeydown(e: KeyboardEvent) {
      if (e.key === 'Escape') {
        e.preventDefault();
        closeModal();
        return;
      }
      if (e.key === 'Tab') {
        const focusable = getFocusable();
        if (focusable.length === 0) return;
        const first = focusable[0];
        const last = focusable[focusable.length - 1];
        if (e.shiftKey && document.activeElement === first) {
          e.preventDefault();
          last.focus();
        } else if (!e.shiftKey && document.activeElement === last) {
          e.preventDefault();
          first.focus();
        }
      }
    }

    function openModal(card: HTMLElement) {
      lastTrigger = card;
      titoloEl!.textContent = card.dataset.titolo || '';
      completoEl!.textContent = card.dataset.completo || '';
      overlay!.classList.add('is-open');
      document.addEventListener('keydown', onKeydown);
      closeBtn!.focus({ preventScroll: true });
    }

    function closeModal() {
      overlay!.classList.remove('is-open');
      document.removeEventListener('keydown', onKeydown);
      if (lastTrigger) {
        lastTrigger.focus({ preventScroll: true });
        lastTrigger = null;
      }
    }

    cards.forEach((card) => {
      card.addEventListener('click', () => openModal(card));
      card.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          openModal(card);
        }
      });
    });

    closeBtn.addEventListener('click', closeModal);
    overlay.addEventListener('click', (e) => {
      if (e.target === overlay) closeModal();
    });

    // Flash highlight della card corrispondente all'hash (#slug).
    // L'hash può non essere ancora applicato al momento di astro:page-load
    // (navigazione con View Transitions), quindi rileggiamo dopo un tick.
    let flashed = false;
    function flashFromHash() {
      if (flashed) return;
      const hash = window.location.hash.replace('#', '');
      if (!hash) return;
      const target = document.getElementById(hash);
      if (target && target.classList.contains('servizio-card')) {
        flashed = true;
        target.scrollIntoView({ behavior: 'smooth', block: 'center' });
        target.classList.add('flash');
        setTimeout(() => target.classList.remove('flash'), 2000);
      }
    }
    // L'hash con View Transitions può essere applicato dopo page-load:
    // riproviamo per una breve finestra finché non lo troviamo.
    [0, 100, 250, 500].forEach((d) => setTimeout(flashFromHash, d));
    window.addEventListener('hashchange', flashFromHash, { once: true });
  }
  document.addEventListener('astro:page-load', initServizi);
</script>

</Layout>
