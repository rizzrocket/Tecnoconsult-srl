---
import Layout from '../layouts/Layout.astro';

// Tutti i clienti delle 3 categorie, in ordine misto, riga unica (no etichette)
const clienti = [
  'Hotel Napoleon — Jesolo',
  'Stratex Bodino — Sutrio (UD)',
  'Hotel Orologio — Venezia',
  'Magazzini Arredo 3 — Scorzè (VE)',
  'Ospedale Civile di Cividale',
  'Falkensteiner Aparthotel — Jesolo',
  'Complesso residenziale — Treviso',
  'Hotel Caorle — Caorle (VE)',
  'Guardia di Finanza FVG',
  'Hotel Rosa Salva — Venezia',
  'Concessionaria Opel e Land Rover — Conegliano',
  'Camping Union Lido — Cavallino (VE)',
  'Hotel Carnia — Carnia (UD)',
  'Complesso residenziale Eraclea — Eraclea (VE)',
  'Grand Hotel Excelsior — Lido di Venezia',
  'Capitaneria di Porto — Trieste',
  'Hotel a Lignano Prata',
  'Complesso polifunzionale — Udine',
  'Hotel Nettuno — Jesolo',
  'Scuole di Fagagna',
  'Hotel Europa Regina',
  'Complesso residenziale — Bibione (VE)',
  'Grand Hotel Victoria — Abano Terme',
  'Ospedale Borgo Trento — Verona',
  'Hotel Allmar — Jesolo',
  'Complesso residenziale — Fagagna (UD)',
  'Hotel a Murano — Venezia',
  'Etigraf — Portogruaro (VE)',
];
---
<Layout>

<!-- ============ HERO ============ -->
<section class="hero">
  <div class="wrap hero-grid">
    <div class="reveal">
      <p class="eyebrow">Agenzia di rappresentanza · dal 1996</p>
      <h1>Tecno Consult Srl</h1>
      <p class="lead">Idro-termo-sanitario, condizionamento ed energie alternative. Supporto tecnico e commerciale per grossisti, installatori e progettisti in Veneto e Friuli Venezia Giulia.</p>
      <div class="cta-row">
        <a href="/contatti" class="btn btn-primary">Richiedi una consulenza</a>
        <a href="/servizi" class="btn btn-ghost">Scopri i servizi</a>
      </div>
    </div>
    <div class="hero-art reveal">
      <div class="hero-logo-stage">
        <div class="hero-logo-halo" aria-hidden="true"></div>
        <img class="hero-logo" src="/images/tecnoconsult-logo.png" alt="Tecno Consult Srl" fetchpriority="high" />
      </div>
    </div>
  </div>

  <div class="datasheet">
    <div class="wrap">
      <div class="ds-item"><div class="ds-key">Fondazione</div><div class="ds-val">1996</div></div>
      <div class="ds-item"><div class="ds-key">Marchi rappresentati</div><div class="ds-val">9</div></div>
      <div class="ds-item"><div class="ds-key">Province coperte</div><div class="ds-val">8</div></div>
      <div class="ds-item"><div class="ds-key">Showroom</div><div class="ds-val">200 m²</div></div>
    </div>
  </div>
</section>

<svg class="pipe-divider" viewBox="0 0 1180 34" preserveAspectRatio="none"><path d="M0,17 H300 V5 H880 V17 H1180" stroke="#2d5563" stroke-width="1.6" fill="none" opacity="0.5"/></svg>

<!-- ============ MARCHI RAPPRESENTATI ============ -->
<div class="marquee-section">
  <div class="wrap">
    <span class="marquee-label">Marchi rappresentati</span>
  </div>
  <div class="marquee">
    <div class="marquee-track">
      <div class="brand-logo-chip"><img src="/images/brands/aquatechnik.png" alt="Aquatechnik" loading="lazy" /></div>
      <div class="brand-logo-chip"><img src="/images/brands/itap.jpg" alt="ITAP" loading="lazy" /></div>
      <div class="brand-logo-chip"><img src="/images/brands/radiant.svg" alt="Radiant" loading="lazy" /></div>
      <div class="brand-logo-chip"><img src="/images/brands/gda.jpg" alt="GDA" loading="lazy" /></div>
      <div class="brand-logo-chip"><img src="/images/brands/gia.png" alt="GIA" loading="lazy" /></div>
      <div class="brand-logo-chip"><img src="/images/brands/fantini-cosmi.png" alt="Fantini Cosmi" loading="lazy" /></div>
      <div class="brand-logo-chip"><img src="/images/brands/winkler-solar.png" alt="Winkler Solar" loading="lazy" /></div>
      <div class="brand-logo-chip"><img src="/images/brands/swell-system.png" alt="Swell System" loading="lazy" /></div>
      <div class="brand-logo-chip"><img src="/images/brands/oli.jpg" alt="OLI" loading="lazy" /></div>
      <!-- duplica per loop -->
      <div class="brand-logo-chip"><img src="/images/brands/aquatechnik.png" alt="Aquatechnik" loading="lazy" /></div>
      <div class="brand-logo-chip"><img src="/images/brands/itap.jpg" alt="ITAP" loading="lazy" /></div>
      <div class="brand-logo-chip"><img src="/images/brands/radiant.svg" alt="Radiant" loading="lazy" /></div>
      <div class="brand-logo-chip"><img src="/images/brands/gda.jpg" alt="GDA" loading="lazy" /></div>
      <div class="brand-logo-chip"><img src="/images/brands/gia.png" alt="GIA" loading="lazy" /></div>
      <div class="brand-logo-chip"><img src="/images/brands/fantini-cosmi.png" alt="Fantini Cosmi" loading="lazy" /></div>
      <div class="brand-logo-chip"><img src="/images/brands/winkler-solar.png" alt="Winkler Solar" loading="lazy" /></div>
      <div class="brand-logo-chip"><img src="/images/brands/swell-system.png" alt="Swell System" loading="lazy" /></div>
      <div class="brand-logo-chip"><img src="/images/brands/oli.jpg" alt="OLI" loading="lazy" /></div>
    </div>
  </div>
</div>

<!-- ============ CHI SIAMO (intro) ============ -->
<section>
  <div class="wrap chisiamo-home">
    <div class="reveal">
      <p class="eyebrow" style="margin-bottom:18px;">Chi siamo</p>
      <p>Tecno Consult è un'agenzia di rappresentanza con sede a San Donà di Piave (VE). Siamo un team di cinque persone con esperienza diretta nel settore termoidraulico — dalla vendita alla progettazione tecnica — al servizio di grossisti, installatori, tecnici e progettisti in Veneto e Friuli Venezia Giulia.</p>
      <div class="cta-row" style="margin-top:22px;">
        <a href="/chi-siamo" class="btn btn-ghost">Scopri il team</a>
        <a href="/contatti" class="btn btn-primary">Contattaci</a>
      </div>
    </div>
    <div class="photo-ph reveal" aria-hidden="true">
      <svg width="34" height="34" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="5" width="18" height="14" rx="2"/><circle cx="8.5" cy="10" r="1.8"/><path d="M21 16l-5-5L5 19" stroke-linecap="round" stroke-linejoin="round"/></svg>
      Foto in arrivo
    </div>
  </div>
</section>

<!-- ============ CHI SI AFFIDA A NOI ============ -->
<section class="section-affida">
  <div class="wrap">
    <span class="marquee-label-affida" style="display:block; margin-bottom:28px;">Chi si affida a noi</span>
  </div>

  <div class="marquee">
    <div class="marquee-track" style="animation-duration:60s;">
      {clienti.map((c) => <div class="ref-chip">{c}</div>)}
      {clienti.map((c) => <div class="ref-chip">{c}</div>)}
    </div>
  </div>

  <div class="wrap" style="margin-top:28px;">
    <a href="/referenze" class="btn btn-ghost">Tutte le referenze →</a>
  </div>
</section>

<svg class="pipe-divider" viewBox="0 0 1180 34" preserveAspectRatio="none"><path d="M0,17 H400 V5 H780 V17 H1180" stroke="#2d5563" stroke-width="1.6" fill="none" opacity="0.5"/></svg>

<section>
  <div class="wrap">
    <div class="section-head reveal">
      <p class="eyebrow">Servizi</p>
      <p>Dall'offerta alla consegna, dal cantiere alla formazione.</p>
    </div>
    <div class="servizi-grid">
      <a href="/servizi#vendita" class="servizio-card reveal">
        <svg width="30" height="30" viewBox="0 0 30 30"><path d="M5,22 L11,10 L19,18 L25,8" fill="none" stroke="#2d5563" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        <h3>Vendita</h3>
        <p>Visite programmate, contratti e listini, affiancamento ai responsabili commerciali.</p>
      </a>
      <a href="/servizi#preventivazione" class="servizio-card reveal">
        <svg width="30" height="30" viewBox="0 0 30 30"><rect x="6" y="6" width="18" height="18" fill="none" stroke="#2d5563" stroke-width="2"/><line x1="6" y1="13" x2="24" y2="13" stroke="#2d5563" stroke-width="1.5"/><line x1="6" y1="19" x2="18" y2="19" stroke="#2d5563" stroke-width="1.5"/></svg>
        <h3>Preventivazione e progettazione</h3>
        <p>Offerte, dimensionamenti e disegni esecutivi a supporto della scelta e dell'installazione.</p>
      </a>
      <a href="/servizi#assistenza-post-vendita" class="servizio-card reveal">
        <svg width="30" height="30" viewBox="0 0 30 30"><path d="M7,16 L13,22 L24,9" fill="none" stroke="#c1632b" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        <h3>Assistenza post-vendita</h3>
        <p>Sopralluoghi in cantiere, supporto tecnico e indirizzamento ai centri assistenza.</p>
      </a>
      <a href="/servizi#centro-didattico" class="servizio-card reveal">
        <svg width="30" height="30" viewBox="0 0 30 30"><rect x="4" y="7" width="22" height="13" rx="1.5" fill="none" stroke="#2d5563" stroke-width="2"/><line x1="11" y1="24" x2="19" y2="24" stroke="#2d5563" stroke-width="2"/><line x1="15" y1="20" x2="15" y2="24" stroke="#2d5563" stroke-width="2"/></svg>
        <h3>Showroom e formazione</h3>
        <p>200 m² di spazio espositivo. Corsi e webinar fino a 30 persone.</p>
      </a>
    </div>
    <div style="margin-top:22px;">
      <a href="/servizi" class="btn btn-ghost">Tutti i servizi →</a>
    </div>
  </div>
</section>

</Layout>
