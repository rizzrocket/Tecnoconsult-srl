  <div class="wrap" style="margin-top:24px;">
    <a href="/referenze" class="btn btn-ghost">Tutte le referenze →</a>
  </div>
</section>

<!-- ============ CHI SIAMO (intro) ============ -->
<section>
  <div class="wrap">
    <div class="reveal" style="max-width:640px;">
      <p class="eyebrow" style="margin-bottom:18px;">Chi siamo</p>
      <p>Tecno Consult è un'agenzia di rappresentanza con sede a San Donà di Piave (VE). Siamo un team di cinque persone con esperienza diretta nel settore termoidraulico — dalla vendita alla progettazione tecnica — al servizio di grossisti, installatori, tecnici e progettisti in Veneto e Friuli Venezia Giulia.</p>
      <div class="cta-row" style="margin-top:22px;">
        <a href="/chi-siamo" class="btn btn-ghost">Scopri il team</a>
        <a href="/contatti" class="btn btn-primary">Contattaci</a>
      </div>
    </div>
  </div>
</section>

<svg class="pipe-divider" viewBox="0 0 1180 34" preserveAspectRatio="none"><path d="M0,17 H400 V5 H780 V17 H1180" stroke="#2d5563" stroke-width="1.6" fill="none" opacity="0.5"/></svg>

<section>
  <div class="wrap">
    <div class="section-head reveal">
      <p class="eyebrow">Servizi</p>
      <p>Dall'offerta alla consegna, dal cantiere alla formazione.</p>
    </div>
    <div class="servizi-grid" style="grid-template-columns:repeat(4,1fr);">
      <div class="servizio-card reveal">
        <svg width="30" height="30" viewBox="0 0 30 30"><path d="M5,22 L11,10 L19,18 L25,8" fill="none" stroke="#2d5563" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        <h3>Vendita</h3>
        <p>Visite programmate, contratti e listini, affiancamento ai responsabili commerciali.</p>
      </div>
      <div class="servizio-card reveal">
        <svg width="30" height="30" viewBox="0 0 30 30"><rect x="6" y="6" width="18" height="18" fill="none" stroke="#2d5563" stroke-width="2"/><line x1="6" y1="13" x2="24" y2="13" stroke="#2d5563" stroke-width="1.5"/><line x1="6" y1="19" x2="18" y2="19" stroke="#2d5563" stroke-width="1.5"/></svg>
        <h3>Preventivazione e progettazione</h3>
        <p>Offerte, dimensionamenti e disegni esecutivi a supporto della scelta e dell'installazione.</p>
      </div>
      <div class="servizio-card reveal">
        <svg width="30" height="30" viewBox="0 0 30 30"><path d="M7,16 L13,22 L24,9" fill="none" stroke="#c1632b" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        <h3>Assistenza post-vendita</h3>
        <p>Sopralluoghi in cantiere, supporto tecnico e indirizzamento ai centri assistenza.</p>
      </div>
      <div class="servizio-card reveal">
        <svg width="30" height="30" viewBox="0 0 30 30"><rect x="4" y="7" width="22" height="13" rx="1.5" fill="none" stroke="#2d5563" stroke-width="2"/><line x1="11" y1="24" x2="19" y2="24" stroke="#2d5563" stroke-width="2"/><line x1="15" y1="20" x2="15" y2="24" stroke="#2d5563" stroke-width="2"/></svg>
        <h3>Showroom e formazione</h3>
        <p>200 m² di spazio espositivo. Corsi e webinar fino a 30 persone.</p>
      </div>
    </div>
    <div style="margin-top:22px;">
      <a href="/servizi" class="btn btn-ghost">Tutti i servizi →</a>
    </div>
  </div>
</section>

</Layout>
