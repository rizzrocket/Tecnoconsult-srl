        <div class="ref-chip">Camping Union Lido, Cavallino</div>
        <div class="ref-chip">Falkensteiner Aparthotel, Jesolo</div>
        <div class="ref-chip">Hotel Napoleon, Jesolo</div>
        <div class="ref-chip">Hotel Nettuno, Jesolo</div>
      </div>
    </div>
  </div>

  <div class="ref-row">
    <span class="ref-cat">Sanità &amp; enti pubblici</span>
    <div class="marquee">
      <div class="marquee-track" style="animation-duration:30s; animation-direction:reverse;">
        <div class="ref-chip">Capitaneria di Porto, Trieste</div>
        <div class="ref-chip">Ospedale Civile di Cividale</div>
        <div class="ref-chip">Guardia di Finanza FVG</div>
        <div class="ref-chip">Ospedale Borgo Trento, Verona</div>
        <div class="ref-chip">Capitaneria di Porto, Trieste</div>
        <div class="ref-chip">Ospedale Civile di Cividale</div>
        <div class="ref-chip">Guardia di Finanza FVG</div>
        <div class="ref-chip">Ospedale Borgo Trento, Verona</div>
      </div>
    </div>
  </div>

  <div class="ref-row">
    <span class="ref-cat">Industria &amp; commercio</span>
    <div class="marquee">
      <div class="marquee-track" style="animation-duration:24s;">
        <div class="ref-chip">Magazzini Arredo 3, Scorzè</div>
        <div class="ref-chip">Etigraf, Portogruaro</div>
        <div class="ref-chip">Magazzini Arredo 3, Scorzè</div>
