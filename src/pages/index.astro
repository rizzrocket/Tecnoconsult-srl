---
import Layout from '../layouts/Layout.astro';
---
<Layout>

<!-- ============ HERO ============ -->
<section class="hero">
  <div class="wrap hero-grid">
    <div class="reveal">
      <p class="eyebrow">Agenzia di rappresentanza · dal 1996</p>
      <h1>Tecno Consult Srl</h1>
      <p class="lead">Idro-termo-sanitario, condizionamento ed energie alternative. Supporto tecnico e commerciale per grossisti, installatori e progettisti in Veneto e Friuli Venezia Giulia.</p>
      <div class="cta-row">
        <a href="/contatti" class="btn btn-primary">Richiedi una consulenza</a>
        <a href="/servizi" class="btn btn-ghost">Scopri i servizi</a>
      </div>
    </div>
    <div class="hero-art reveal">
      <div class="hero-logo-stage">
        <div class="hero-logo-halo" aria-hidden="true"></div>
        <img class="hero-logo" src="/images/tecnoconsult-logo.png" alt="Tecno Consult Srl" />
      </div>
    </div>
  </div>

  <div class="datasheet">
    <div class="wrap">
      <div class="ds-item"><div class="ds-key">Fondazione</div><div class="ds-val">1996</div></div>
      <div class="ds-item"><div class="ds-key">Marchi rappresentati</div><div class="ds-val">9</div></div>
      <div class="ds-item"><div class="ds-key">Province coperte</div><div class="ds-val">8</div></div>
      <div class="ds-item"><div class="ds-key">Showroom</div><div class="ds-val">200 m²</div></div>
    </div>
  </div>
</section>

<svg class="pipe-divider" viewBox="0 0 1180 34" preserveAspectRatio="none"><path d="M0,17 H300 V5 H880 V17 H1180" stroke="#2d5563" stroke-width="1.6" fill="none" opacity="0.5"/></svg>

<!-- ============ MARCHI RAPPRESENTATI ============ -->
<div class="marquee-section">
  <div class="wrap">
    <span class="marquee-label">Marchi rappresentati</span>
  </div>
  <div class="marquee">
    <div class="marquee-track">
      <div class="brand-logo-chip"><img src="/images/brands/aquatechnik.png" alt="Aquatechnik" /></div>
      <div class="brand-logo-chip"><img src="/images/brands/itap.jpg" alt="ITAP" /></div>
      <div class="brand-logo-chip"><img src="/images/brands/radiant.svg" alt="Radiant" /></div>
      <div class="brand-logo-chip"><img src="/images/brands/gda.jpg" alt="GDA" /></div>
      <div class="brand-logo-chip"><img src="/images/brands/gia.png" alt="GIA" /></div>
      <div class="brand-logo-chip"><img src="/images/brands/fantini-cosmi.png" alt="Fantini Cosmi" /></div>
      <div class="brand-logo-chip"><img src="/images/brands/winkler-solar.png" alt="Winkler Solar" /></div>
      <div class="brand-logo-chip"><img src="/images/brands/swell-system.png" alt="Swell System" /></div>
      <div class="brand-logo-chip"><img src="/images/brands/oli.jpg" alt="OLI" /></div>
      <!-- duplica per loop -->
      <div class="brand-logo-chip"><img src="/images/brands/aquatechnik.png" alt="Aquatechnik" /></div>
      <div class="brand-logo-chip"><img src="/images/brands/itap.jpg" alt="ITAP" /></div>
      <div class="brand-logo-chip"><img src="/images/brands/radiant.svg" alt="Radiant" /></div>
      <div class="brand-logo-chip"><img src="/images/brands/gda.jpg" alt="GDA" /></div>
      <div class="brand-logo-chip"><img src="/images/brands/gia.png" alt="GIA" /></div>
      <div class="brand-logo-chip"><img src="/images/brands/fantini-cosmi.png" alt="Fantini Cosmi" /></div>
      <div class="brand-logo-chip"><img src="/images/brands/winkler-solar.png" alt="Winkler Solar" /></div>
      <div class="brand-logo-chip"><img src="/images/brands/swell-system.png" alt="Swell System" /></div>
      <div class="brand-logo-chip"><img src="/images/brands/oli.jpg" alt="OLI" /></div>
    </div>
  </div>
</div>

<div class="wrap banner-image-wrap reveal">
  <img class="banner-image" src="/images/stock-saldatura.jpg" alt="Lavorazione industriale in officina" loading="lazy" />
</div>

<!-- ============ CHI SI AFFIDA A NOI ============ -->
<section class="section-affida">
  <div class="wrap">
    <span class="marquee-label-affida" style="display:block; margin-bottom:28px;">Chi si affida a noi</span>
  </div>

  <div class="ref-row">
    <span class="ref-cat">Hotellerie</span>
    <div class="marquee">
      <div class="marquee-track" style="animation-duration:48s;">
        <div class="ref-chip">Grand Hotel Excelsior — Lido di Venezia</div>
        <div class="ref-chip">Hotel Allmar — Jesolo</div>
        <div class="ref-chip">Falkensteiner Aparthotel — Jesolo</div>
        <div class="ref-chip">Hotel Napoleon — Jesolo</div>
        <div class="ref-chip">Hotel Nettuno — Jesolo</div>
        <div class="ref-chip">Hotel Caorle — Caorle (VE)</div>
        <div class="ref-chip">Camping Union Lido — Cavallino (VE)</div>
        <div class="ref-chip">Hotel a Lignano Prata</div>
        <div class="ref-chip">Grand Hotel Victoria — Abano Terme</div>
        <div class="ref-chip">Hotel Orologio — Venezia</div>
        <div class="ref-chip">Hotel Rosa Salva — Venezia</div>
        <div class="ref-chip">Hotel a Murano — Venezia</div>
        <div class="ref-chip">Hotel Europa Regina</div>
        <div class="ref-chip">Hotel Carnia — Carnia (UD)</div>
        <div class="ref-chip">Grand Hotel Excelsior — Lido di Venezia</div>
        <div class="ref-chip">Hotel Allmar — Jesolo</div>
        <div class="ref-chip">Falkensteiner Aparthotel — Jesolo</div>
