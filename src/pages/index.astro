---
import Layout from '../layouts/Layout.astro';
---
<Layout>

<header>
  <div class="nav">
    <a href="#" class="brand">
      <img src="/images/tecnoconsult-icon.png" alt="Tecno Consult Srl" />
      <span class="brand-word">TECNO<span>CONSULT</span></span>
    </a>
    <ul class="nav-links">
      <li><a href="#chisiamo">Chi siamo</a></li>
      <li><a href="#servizi">Servizi</a></li>
      <li><a href="#dove-operiamo">Dove operiamo</a></li>
      <li><a href="#referenze">Referenze</a></li>
      <li><a href="#contatti">Contatti</a></li>
    </ul>
    <a class="nav-tel" href="tel:+390421512000421-51200">0421 51200</a>
  </div>
</header>

<!-- ============ HERO ============ -->
<section class="hero">
  <div class="wrap hero-grid">
    <div class="reveal">
      <p class="eyebrow">Agenzia di rappresentanza · dal 1996</p>
      <h1>Tecno Consult Srl</h1>
      <p class="lead">Idro-termo-sanitario, condizionamento ed energie alternative. Supporto tecnico e commerciale per grossisti, installatori e progettisti in Veneto e Friuli Venezia Giulia.</p>
      <div class="cta-row">
        <a href="#contatti" class="btn btn-primary">Richiedi una consulenza</a>
        <a href="#servizi" class="btn btn-ghost">Scopri i servizi</a>
      </div>
    </div>
    <div class="hero-art reveal">
      <div class="hero-logo-stage">
        <div class="hero-logo-halo" aria-hidden="true"></div>
        <img class="hero-logo" src="/images/tecnoconsult-logo.png" alt="Tecno Consult Srl" />
      </div>
    </div>
  </div>

  <div class="datasheet">
    <div class="wrap">
      <div class="ds-item"><div class="ds-key">Fondazione</div><div class="ds-val">1996</div></div>
      <div class="ds-item"><div class="ds-key">Marchi rappresentati</div><div class="ds-val">9</div></div>
      <div class="ds-item"><div class="ds-key">Province coperte</div><div class="ds-val">8</div></div>
      <div class="ds-item"><div class="ds-key">Showroom</div><div class="ds-val">200 m²</div></div>
    </div>
  </div>
</section>

<svg class="pipe-divider" viewBox="0 0 1180 34" preserveAspectRatio="none"><path d="M0,17 H300 V5 H880 V17 H1180" stroke="#2d5563" stroke-width="1.6" fill="none" opacity="0.5"/></svg>

<!-- ============ CHI SIAMO ============ -->
<section id="chisiamo">
  <div class="wrap chisiamo">
    <div class="reveal">
      <p class="eyebrow" style="margin-bottom:18px;">Chi siamo</p>
      <p>Tecno Consult è un'agenzia di rappresentanza con sede a San Donà di Piave (VE). Siamo un team di cinque persone con esperienza diretta nel settore termoidraulico — dalla vendita alla progettazione tecnica — al servizio di grossisti, installatori, tecnici e progettisti in Veneto e Friuli Venezia Giulia.</p>
      <p>Rappresentiamo 9 marchi di riferimento del settore e affianchiamo i nostri clienti dalla scelta del prodotto fino al cantiere.</p>
    </div>
    <div class="founder-card reveal">
      <div class="ds-key">Fondatore</div>
      <div class="founder-name">Mauro Scarabel</div>
      <div class="founder-role">Titolare — vendite e relazioni commerciali</div>
      <div style="height:1px; background:var(--line-soft); margin:16px 0;"></div>
      <div class="ds-key">Sede operativa</div>
      <p style="font-size:0.86rem; color:var(--ink-soft); margin-top:6px; line-height:1.5;">Via Barcis 2<br>30027 San Donà di Piave (VE)</p>
    </div>
  </div>

  <div class="wrap">
    <div class="team-grid">
      <div class="team-card reveal">
        <div class="avatar">MS</div>
        <div class="team-name">Mauro Scarabel</div>
        <div class="team-role">Titolare — vendite e relazioni</div>
        <a class="team-contact" href="mailto:mauro.scarabel@tecnoconsult-srl.it">mauro.scarabel@<br>tecnoconsult-srl.it</a>
      </div>
      <div class="team-card reveal">
        <div class="avatar">LF</div>
        <div class="team-name">Laura Ferrazzo</div>
        <div class="team-role">Marketing — contatti e appuntamenti</div>
        <a class="team-contact" href="mailto:marketing@tecnoconsult-srl.it">marketing@<br>tecnoconsult-srl.it</a>
      </div>
      <div class="team-card reveal">
        <div class="avatar">MS</div>
        <div class="team-name">Monica Scarabel</div>
        <div class="team-role">Gestione ordini e amministrazione</div>
        <a class="team-contact" href="mailto:info@tecnoconsult-srl.it">info@<br>tecnoconsult-srl.it</a>
      </div>
      <div class="team-card reveal">
        <div class="avatar">MC</div>
        <div class="team-name">Maurizio Callegarin</div>
        <div class="team-role">Consulenza, promozione, formazione</div>
        <a class="team-contact" href="mailto:maurizio.callegarin@tecnoconsult-srl.it">maurizio.callegarin@<br>tecnoconsult-srl.it</a>
      </div>
      <div class="team-card reveal">
        <div class="avatar">FM</div>
        <div class="team-name">Francesco Mazziotta</div>
        <div class="team-role">Ufficio tecnico — preventivazione</div>
        <a class="team-contact" href="mailto:tecnico@tecnoconsult-srl.it">tecnico@<br>tecnoconsult-srl.it</a>
      </div>
    </div>
    <p class="photo-note">Foto del team da inserire — placeholder con iniziali in attesa degli scatti reali.</p>
  </div>
</section>

<!-- ============ MARCHI RAPPRESENTATI ============ -->
<div class="marquee-section">
  <div class="wrap">
    <span class="marquee-label">Marchi rappresentati</span>
  </div>
  <div class="marquee">
    <div class="marquee-track">
      <div class="brand-chip">AQUATECHNIK</div>
      <div class="brand-chip">ITAP</div>
      <div class="brand-chip">RADIANT</div>
      <div class="brand-chip">GDA</div>
      <div class="brand-chip">AQUATECHNIK</div>
      <div class="brand-chip">ITAP</div>
      <div class="brand-chip">RADIANT</div>
      <div class="brand-chip">GDA</div>
    </div>
  </div>
  <div class="wrap">
    <p class="brand-note">+ Gia SpA · Fantini Cosmi · Winkler Solar · Swell System · Oli Srl — loghi in arrivo.</p>
  </div>
</div>

<!-- ============ DOVE OPERIAMO ============ -->
<section id="dove-operiamo">
  <div class="wrap dove">
    <div class="reveal">
      <p class="eyebrow" style="margin-bottom:16px;">Dove operiamo</p>
      <p style="line-height:1.7;">Operiamo nel mercato idro-termo-sanitario, condizionamento, trattamento aria e acqua ed energie alternative — settori civile, industriale, terziario, commerciale, navale, alberghiero e termale.</p>
      <ul class="dove-list">
        <li><b>8</b> province tra Veneto e FVG</li>
        <li><b>Grossisti</b> e rivenditori</li>
        <li><b>Installatori</b>, tecnici e progettisti</li>
      </ul>
    </div>
    <div class="reveal" style="display:flex; justify-content:center;">
      <svg width="280" height="280" viewBox="0 0 280 280" fill="none">
        <g opacity="0.4">
          <path d="M0,70 H280 M0,140 H280 M0,210 H280" stroke="#2d5563" stroke-width="0.6"/>
          <path d="M70,0 V280 M140,0 V280 M210,0 V280" stroke="#2d5563" stroke-width="0.6"/>
        </g>
        <path d="M90,60 L150,50 L200,90 L210,150 L180,210 L120,225 L75,180 L60,110 Z" fill="#2d5563" opacity="0.12" stroke="#2d5563" stroke-width="2"/>
        <circle cx="150" cy="130" r="6" fill="#c1632b"/>
        <text x="150" y="115" text-anchor="middle" font-family="IBM Plex Mono" font-size="10" fill="#16242a">SAN DONÀ DI PIAVE</text>
      </svg>
    </div>
  </div>
</section>

<svg class="pipe-divider" viewBox="0 0 1180 34" preserveAspectRatio="none"><path d="M0,17 H880 V29 H300 V17 H1180" stroke="#2d5563" stroke-width="1.6" fill="none" opacity="0.5"/></svg>

<!-- ============ SERVIZI ============ -->
<section id="servizi">
  <div class="wrap">
    <div class="section-head reveal">
      <p class="eyebrow">Servizi</p>
      <p>Sette aree di servizio, un'unica squadra che segue il prodotto in tutte le sue fasi.</p>
    </div>
    <div class="servizi-grid">
      <div class="servizio-card reveal">
        <svg width="30" height="30" viewBox="0 0 30 30"><path d="M5,22 L11,10 L19,18 L25,8" fill="none" stroke="#2d5563" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        <h3>Vendita</h3>
        <p>Visite programmate, contratti e listini, affiancamento ai responsabili commerciali.</p>
      </div>
      <div class="servizio-card reveal">
        <svg width="30" height="30" viewBox="0 0 30 30"><path d="M6,12 L6,18 L11,18 L18,24 V6 L11,12 Z" fill="none" stroke="#2d5563" stroke-width="2" stroke-linejoin="round"/><path d="M21,11 Q24,15 21,19" fill="none" stroke="#c1632b" stroke-width="2"/></svg>
        <h3>Promozione esterna</h3>
        <p>Cataloghi, corsi, eventi e aggiornamento continuo della clientela sul territorio.</p>
      </div>
      <div class="servizio-card reveal">
        <svg width="30" height="30" viewBox="0 0 30 30"><rect x="6" y="6" width="18" height="18" fill="none" stroke="#2d5563" stroke-width="2"/><line x1="6" y1="13" x2="24" y2="13" stroke="#2d5563" stroke-width="1.5"/><line x1="6" y1="19" x2="18" y2="19" stroke="#2d5563" stroke-width="1.5"/></svg>
        <h3>Preventivazione e progettazione</h3>
        <p>Offerte, dimensionamenti e disegni esecutivi a supporto della scelta e dell'installazione.</p>
      </div>
      <div class="servizio-card reveal">
        <svg width="30" height="30" viewBox="0 0 30 30"><rect x="5" y="9" width="20" height="14" rx="1.5" fill="none" stroke="#2d5563" stroke-width="2"/><path d="M5,9 L15,17 L25,9" fill="none" stroke="#2d5563" stroke-width="2"/></svg>
        <h3>Segreteria</h3>
        <p>Gestione ordini, disponibilità prodotti, appuntamenti e aggiornamenti commerciali.</p>
      </div>
      <div class="servizio-card reveal">
        <svg width="30" height="30" viewBox="0 0 30 30"><circle cx="13" cy="13" r="8" fill="none" stroke="#2d5563" stroke-width="2"/><line x1="19" y1="19" x2="25" y2="25" stroke="#2d5563" stroke-width="2" stroke-linecap="round"/></svg>
        <h3>Assistenza pre-vendita</h3>
        <p>Formazione e accreditamento dei centri assistenza sui prodotti rappresentati.</p>
      </div>
      <div class="servizio-card reveal">
        <svg width="30" height="30" viewBox="0 0 30 30"><path d="M7,16 L13,22 L24,9" fill="none" stroke="#c1632b" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        <h3>Assistenza post-vendita</h3>
        <p>Sopralluoghi in cantiere, supporto tecnico e indirizzamento ai centri assistenza.</p>
      </div>
      <div class="servizio-card reveal">
        <svg width="30" height="30" viewBox="0 0 30 30"><rect x="4" y="7" width="22" height="13" rx="1.5" fill="none" stroke="#2d5563" stroke-width="2"/><line x1="11" y1="24" x2="19" y2="24" stroke="#2d5563" stroke-width="2"/><line x1="15" y1="20" x2="15" y2="24" stroke="#2d5563" stroke-width="2"/></svg>
        <h3>Centro didattico e showroom</h3>
        <p>200 m² di spazio espositivo e formativo, corsi e webinar fino a 30 persone.</p>
      </div>
    </div>
  </div>
</section>

<!-- ============ MISSION ============ -->
<section>
  <div class="wrap">
    <div class="section-head reveal">
      <p class="eyebrow">Mission</p>
    </div>
    <p class="mission-statement reveal">Mettiamo la nostra esperienza nel settore idro-termo-sanitario al servizio delle aziende che rappresentiamo e dei clienti che le scelgono.</p>
    <div class="pillars reveal">
      <div class="pillar">
        <h3>Competenza tecnica</h3>
        <p>Formazione continua su prodotti, normative e applicazioni.</p>
      </div>
      <div class="pillar">
        <h3>Vicinanza al cliente</h3>
        <p>Visite costanti, consulenza diretta, supporto in cantiere.</p>
      </div>
      <div class="pillar">
        <h3>Affidabilità nel tempo</h3>
        <p>Quasi 30 anni di relazioni nel Triveneto.</p>
      </div>
    </div>
  </div>
</section>

<!-- ============ REFERENZE ============ -->
<div class="marquee-section" id="referenze">
  <div class="wrap">
    <span class="marquee-label">Chi si affida a noi</span>
  </div>

  <div class="ref-row">
    <span class="ref-cat">Hotellerie</span>
    <div class="marquee">
      <div class="marquee-track" style="animation-duration:36s;">
