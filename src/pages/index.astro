        <div class="ref-chip">Hotel Caorle — Caorle (VE)</div>
        <div class="ref-chip">Camping Union Lido — Cavallino (VE)</div>
        <div class="ref-chip">Hotel a Lignano Prata</div>
        <div class="ref-chip">Grand Hotel Victoria — Abano Terme</div>
        <div class="ref-chip">Hotel Orologio — Venezia</div>
        <div class="ref-chip">Hotel Rosa Salva — Venezia</div>
        <div class="ref-chip">Hotel a Murano — Venezia</div>
        <div class="ref-chip">Hotel Europa Regina</div>
        <div class="ref-chip">Hotel Carnia — Carnia (UD)</div>
      </div>
    </div>
  </div>

  <div class="ref-row" style="margin-top:14px;">
    <span class="ref-cat">Sanità &amp; enti pubblici</span>
    <div class="marquee">
      <div class="marquee-track" style="animation-duration:30s; animation-direction:reverse;">
        <div class="ref-chip">Ospedale Civile di Cividale</div>
        <div class="ref-chip">Ospedale Borgo Trento — Verona</div>
        <div class="ref-chip">Capitaneria di Porto — Trieste</div>
        <div class="ref-chip">Guardia di Finanza FVG</div>
        <div class="ref-chip">Scuole di Fagagna</div>
        <div class="ref-chip">Ospedale Civile di Cividale</div>
