    </div>
  </div>

  <div class="ref-row" style="margin-top:14px;">
    <span class="ref-cat">Industria &amp; residenziale</span>
    <div class="marquee">
      <div class="marquee-track" style="animation-duration:38s;">
        <div class="ref-chip">Magazzini Arredo 3 — Scorzè (VE)</div>
        <div class="ref-chip">Etigraf — Portogruaro (VE)</div>
