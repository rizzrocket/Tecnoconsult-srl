---
import { ViewTransitions } from 'astro:transitions';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  lang?: string;
}
const {
  title = 'Tecno Consult Srl — Agenzia di rappresentanza dal 1996',
  description = 'Idro-termo-sanitario, condizionamento ed energie alternative. Supporto tecnico e commerciale per grossisti, installatori e progettisti in Veneto e Friuli Venezia Giulia.',
  lang = 'it',
} = Astro.props;

const canonical = Astro.site
  ? new URL(Astro.url.pathname, Astro.site).href
  : Astro.url.href;
---
<!doctype html>
<html lang={lang}>
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="description" content={description} />
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;700&family=IBM+Plex+Sans:wght@400;500;600&family=IBM+Plex+Mono:wght@500;600&display=swap" rel="stylesheet">
<title>{title}</title>
<link rel="canonical" href={canonical} />
<link rel="icon" type="image/png" href="/images/favicon-tc.png?v=2" />
<link rel="apple-touch-icon" href="/images/favicon-tc.png?v=2" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:type" content="website" />
<meta property="og:url" content={canonical} />
<meta property="og:site_name" content="Tecno Consult Srl" />
<meta property="og:locale" content="it_IT" />
<meta property="og:image" content="https://tecnoconsult-srl.it/images/tecnoconsult-logo.png" />
<meta property="og:image:width" content="512" />
<meta property="og:image:height" content="512" />
<meta name="twitter:card" content="summary" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<ViewTransitions fallback="swap" />
<style is:global>
  :root{
    --paper:#eef2f1;
    --paper-2:#e6ebea;
    --surface:#ffffff;
    --tint:#dee6e6;
    --ink:#16242a;
    --ink-soft:#46565c;
    --petrol:#2d5563;
    --petrol-deep:#1c3a45;
    --copper:#c1632b;
    --line:#bcccc9;
    --line-soft:#d8e1df;
    --radius:10px;
    --maxw:1180px;
  }
  *{box-sizing:border-box;}
  html{scroll-behavior:smooth;}
  body{
    margin:0;
    overflow-x:hidden;
    /* fondo lavorato: gradiente tenue + reticolo tecnico "carta blueprint"
       a bassissima opacità; visibile solo nelle sezioni senza fascia piena */
    background-color:var(--paper);
    background-image:
      repeating-linear-gradient(0deg, rgba(45,85,99,0.035) 0 1px, transparent 1px 34px),
      repeating-linear-gradient(90deg, rgba(45,85,99,0.035) 0 1px, transparent 1px 34px),
      linear-gradient(180deg, var(--paper) 0%, var(--paper-2) 100%);
    background-attachment:fixed;
    color:var(--ink);
    font-family:'IBM Plex Sans',sans-serif;
    -webkit-font-smoothing:antialiased;
  }
  a{color:inherit;}
  .wrap{max-width:var(--maxw); margin:0 auto; padding:0 28px;}
  h1,h2,h3{font-family:'Space Grotesk',sans-serif; margin:0; letter-spacing:-0.01em;}
  p{margin:0;}
  :focus-visible{outline:2px solid var(--copper); outline-offset:3px;}

  .eyebrow{
    font-family:'IBM Plex Mono',monospace;
    font-size:0.78rem;
    letter-spacing:0.12em;
    text-transform:uppercase;
    color:var(--petrol);
    font-weight:600;
    display:inline-flex;
    align-items:center;
    gap:10px;
  }
  /* indicatore tecnico copper prima dell'etichetta */
  .eyebrow::before{
    content:"";
    width:18px;
    height:2px;
    background:var(--copper);
    flex-shrink:0;
  }
  /* ---------- reveal ---------- */
  .reveal{opacity:0; transform:translateY(16px); transition:opacity .6s ease, transform .6s ease;}
  .reveal.is-visible{opacity:1; transform:none;}
  @media (prefers-reduced-motion:reduce){
    .reveal{opacity:1; transform:none; transition:none;}
  }

  /* ---------- nav ---------- */
  header{
    position:sticky; top:0; z-index:50;
    /* barra menu in marrone mocha con scritte bianche.
       PER RIPRISTINARE l'originale: background:rgba(238,242,241,0.92);
       border-bottom:1px solid var(--line-soft); e rimettere i colori testo:
       .brand-word=var(--ink) / span=var(--petrol); .nav-links a=var(--ink-soft),
       hover/current=var(--petrol); .nav-tel border+color=var(--petrol),
       hover bg=var(--petrol); .nav-tel-mobile a=var(--copper);
       .nav-toggle span background=var(--ink). */
    background:rgba(150,114,90,0.97);
    backdrop-filter:blur(6px);
    border-bottom:1px solid rgba(90,60,44,0.4);
  }
  .nav{display:flex; align-items:center; justify-content:space-between; padding:16px 28px; max-width:var(--maxw); margin:0 auto;}
  .brand{display:flex; align-items:center; gap:10px; text-decoration:none;}
  .brand img{height:30px; width:auto; display:block;}
  .brand-word{font-family:'Space Grotesk',sans-serif; font-weight:700; font-size:1.02rem; color:#fff; letter-spacing:-0.01em;}
  .brand-word span{color:rgba(255,255,255,0.82);}
  .nav-links{display:flex; gap:26px; list-style:none; margin:0; padding:0;}
  .nav-links a{font-size:0.86rem; text-decoration:none; color:rgba(255,255,255,0.9); font-weight:500;}
  .nav-links a:hover{color:#fff;}
  .nav-links a[aria-current="page"]{color:#fff; font-weight:600;}
  .nav-tel{
    font-family:'IBM Plex Mono',monospace;
    font-size:0.82rem;
    border:1px solid rgba(255,255,255,0.7);
    color:#fff;
    padding:7px 14px;
    border-radius:999px;
    text-decoration:none;
    white-space:nowrap;
  }
  .nav-tel:hover{background:#fff; color:#96725a;}
  .nav-tel-mobile{display:none;}
  .nav-toggle-input{display:none;}
  .nav-toggle{
    display:none;
    flex-direction:column;
    justify-content:center;
    align-items:center;
    gap:5px;
    width:44px;
    height:44px;
    cursor:pointer;
    flex-shrink:0;
  }
  .nav-toggle span{width:24px;}
  .nav-toggle span{display:block; width:100%; height:2px; background:#fff; border-radius:2px; transition:transform .25s ease, opacity .25s ease;}
  .nav-toggle-input:checked ~ .nav-toggle span:nth-child(1){transform:translateY(7px) rotate(45deg);}
  .nav-toggle-input:checked ~ .nav-toggle span:nth-child(2){opacity:0;}
  .nav-toggle-input:checked ~ .nav-toggle span:nth-child(3){transform:translateY(-7px) rotate(-45deg);}

  /* ---------- hero ---------- */
  .hero{
    position:relative;
    overflow:hidden;
    padding:64px 0 0;
    background-image:
      linear-gradient(rgba(238,242,241,0.94),rgba(238,242,241,0.94)),
      repeating-linear-gradient(0deg, rgba(45,85,99,0.07) 0 1px, transparent 1px 28px),
      repeating-linear-gradient(90deg, rgba(45,85,99,0.07) 0 1px, transparent 1px 28px);
  }
  .hero-grid{
    display:grid;
    grid-template-columns:1.1fr 1fr;
    gap:40px;
    align-items:center;
    padding-bottom:46px;
  }
  .hero h1{font-size:2.7rem; line-height:1.08; margin:14px 0 16px; color:var(--ink);}
  .hero p.lead{font-size:1.04rem; color:var(--ink-soft); max-width:460px; line-height:1.6; margin-bottom:26px;}
  .cta-row{display:flex; gap:14px; flex-wrap:wrap;}
  .btn{
    font-family:'IBM Plex Sans',sans-serif;
    font-weight:600;
    font-size:0.92rem;
    padding:13px 22px;
    border-radius:6px;
    text-decoration:none;
    display:inline-flex;
    align-items:center;
    gap:8px;
  }
  .btn-primary{background:var(--petrol); color:#fff;}
  .btn-primary:hover{background:var(--petrol-deep);}
  .btn-ghost{border:1px solid var(--line); color:var(--ink);}
  .btn-ghost:hover{border-color:var(--petrol); color:var(--petrol);}

  .hero-art{display:flex; justify-content:center;}
  .hero-logo-stage{
    position:relative;
    display:flex;
    align-items:center;
    justify-content:center;
    width:100%;
    max-width:340px;
    aspect-ratio:16/10;
  }
  .hero-logo-halo{
    position:absolute;
    inset:0;
    border-radius:50%;
    background:radial-gradient(closest-side, rgba(193,99,43,0.16), rgba(45,85,99,0.14) 55%, transparent 75%);
    filter:blur(18px);
  }
  .hero-logo{
    position:relative;
    width:82%;
    max-width:260px;
    height:auto;
    animation:logoScaleIn .9s ease-out both, logoBreathe 6s ease-in-out 0.9s infinite;
  }
  @keyframes logoScaleIn{ from{opacity:0; transform:scale(0.92);} to{opacity:1; transform:scale(1);} }
  @keyframes logoBreathe{ 0%,100%{transform:scale(1);} 50%{transform:scale(1.02);} }
  @media (prefers-reduced-motion:reduce){
    .hero-logo{animation:none;}
  }

  .sr-only{
    position:absolute; width:1px; height:1px; padding:0; margin:-1px;
    overflow:hidden; clip:rect(0,0,0,0); white-space:nowrap; border:0;
  }

  /* ---------- datasheet strip ---------- */
  .datasheet{
    border-top:2px solid var(--petrol);
    border-bottom:1px solid var(--line);
    background:var(--surface);
  }
  .datasheet .wrap{
    display:grid;
    grid-template-columns:repeat(4,1fr);
  }
  .ds-item{
    padding:22px 24px;
    border-right:1px solid var(--line-soft);
  }
  .ds-item:last-child{border-right:none;}
  .ds-key{font-family:'IBM Plex Mono',monospace; font-size:0.68rem; letter-spacing:0.1em; color:var(--ink-soft); text-transform:uppercase;}
  .ds-val{font-family:'IBM Plex Mono',monospace; font-size:1.5rem; font-weight:600; color:var(--petrol); margin-top:4px;}

  /* ---------- pipe divider ---------- */
  .pipe-divider{display:block; width:100%; height:34px;}

  section{padding:clamp(44px,6vw,60px) 0;}
  /* fasce con intro breve iniziale a inizio pagina interna: meno banda vuota
     sotto l'header, il contenuto parte presto */
  .section--intro{padding-top:clamp(24px,3.4vw,34px);}
  .section-head{margin-bottom:34px; max-width:680px;}
  /* Titoli di sezione presenti ma non giganti — regola condivisa
     tra gli h2 dentro .section-head e gli h2 sciolti con .sec-title */
  .section-head h2, .sec-title{
    font-family:'Space Grotesk',sans-serif;
    font-size:clamp(1.6rem, 1.05rem + 1.7vw, 2.25rem);
    line-height:1.12; letter-spacing:-0.02em; font-weight:700;
    color:var(--ink); margin:0 0 12px;
  }
  .section-head h2::after, .sec-title::after{
    content:""; display:block; width:44px; height:3px;
    background:var(--copper); margin-top:12px;
  }
  .section-head--center h2::after{margin-left:auto; margin-right:auto;}
  .section-head .eyebrow{margin-bottom:8px;}
  .section-head p{color:var(--ink-soft); margin-top:12px; line-height:1.6;}
  /* titolo forte centrato come apertura di una sezione chiave */
  .section-head--center{max-width:760px; margin-left:auto; margin-right:auto; text-align:center;}
  .section-head--center .eyebrow{justify-content:center;}

  /* ---------- chi siamo ---------- */
  .chisiamo-intro{max-width:720px;}
  .chisiamo-intro p{font-size:1rem; line-height:1.7; color:var(--ink);}
  .chisiamo-intro p + p{margin-top:14px;}
  /* founder come biglietto da visita: ritratto ampio affiancato ai dati (Mauro
     è il volto dell'azienda → ritratto non più piccolo dei ritratti team) */
  .founder-card{
    max-width:620px;
    margin-top:30px;
    border:1px solid var(--line);
    border-top:3px solid var(--petrol);
    border-radius:var(--radius);
    background:var(--surface);
    padding:24px 26px;
    display:grid;
    grid-template-columns:250px 1fr;
    gap:28px;
    align-items:center;
  }
  .founder-photo{aspect-ratio:4/5; margin:0; overflow:hidden; border:1px solid var(--line-soft); border-radius:var(--radius); background:var(--surface);}
  .founder-photo img{display:block; width:100%; height:100%; object-fit:cover; object-position:center 40%;}
  .founder-body{min-width:0;}
  /* intro chi-siamo a due schede: Mauro + "Il nostro Team" (foto di gruppo) */
  .intro-duo{display:grid; grid-template-columns:1.15fr 0.85fr; gap:22px; align-items:stretch; margin-top:30px;}
  .intro-duo .founder-card{max-width:none; margin-top:0;}
  .team-photo-card{display:flex; flex-direction:column; overflow:hidden; border:1px solid var(--line); border-top:3px solid var(--copper); border-radius:var(--radius); background:var(--surface);}
  .team-photo-card h3{font-family:'Space Grotesk',sans-serif; font-weight:700; font-size:1.15rem; color:var(--ink); padding:20px 24px 14px;}
  .team-photo-card figure{margin:0; flex:1; min-height:0;}
  .team-photo-card img{display:block; width:100%; height:100%; object-fit:cover; min-height:240px;}
  @media (max-width:760px){
    .intro-duo{grid-template-columns:1fr;}
  }
  .founder-card .ds-key{margin-bottom:6px;}
  .founder-card .founder-name{font-family:'Space Grotesk',sans-serif; font-weight:700; font-size:1.15rem;}
  .founder-card .founder-role{font-size:0.86rem; color:var(--ink-soft); margin-top:2px;}
  @media (max-width:560px){
    .founder-card{grid-template-columns:1fr; max-width:340px;}
    .founder-photo{max-width:240px;}
  }

  /* ---------- team ---------- */
  .team-grid{
    display:grid;
    grid-template-columns:repeat(3,minmax(0,260px));
    justify-content:center;
    gap:22px;
    margin-top:14px;
  }
  .team-card{
    background:var(--surface);
    border:1px solid var(--line-soft);
    border-radius:var(--radius);
    padding:14px;
    text-align:left;
  }
  /* ritratto: riquadro 4:5 con foto reale (object-fit cover) */
  .team-portrait{
    aspect-ratio:4/5;
    margin-bottom:12px;
    overflow:hidden;
    border:1px solid var(--line-soft);
    border-radius:var(--radius);
    background:var(--surface);
  }
  .team-portrait img{display:block; width:100%; height:100%; object-fit:cover; object-position:center 38%;}
  .team-name{font-weight:600; font-size:0.94rem;}
  .team-role{font-size:0.78rem; color:var(--ink-soft); margin-top:3px; line-height:1.4; min-height:1px;}
  .team-contact{font-family:'IBM Plex Mono',monospace; font-size:0.68rem; color:var(--petrol); margin-top:8px; word-break:break-word; display:block; text-decoration:none;}
  .photo-note{font-size:0.72rem; color:var(--ink-soft); margin-top:16px; font-style:italic;}
  @media (max-width:920px){
    .team-grid{grid-template-columns:repeat(3,1fr);}
  }

  /* ---------- marquee ---------- */
  .marquee-section{background:var(--surface); border-top:1px solid var(--line); border-bottom:1px solid var(--line); padding:42px 0;}
  .marquee-label{font-family:'IBM Plex Mono',monospace; font-size:0.7rem; letter-spacing:0.12em; text-transform:uppercase; color:var(--ink-soft); margin-bottom:18px; display:block;}
  .marquee-label-affida{
    text-align:center;
    color:var(--copper);
    font-weight:700;
    font-family:'Space Grotesk',sans-serif;
    font-size:1.1rem;
    letter-spacing:-0.01em;
    text-transform:none;
    margin-bottom:28px;
  }
  .marquee{overflow:hidden; position:relative; mask-image:linear-gradient(90deg, transparent, #000 6%, #000 94%, transparent);}
  .marquee-track{display:flex; gap:18px; width:max-content; animation:scrollLeft 32s linear infinite; will-change:transform; backface-visibility:hidden;}
  .marquee:hover .marquee-track{animation-play-state:paused;}
  @keyframes scrollLeft{ from{transform:translateX(0);} to{transform:translateX(-50%);} }
  @media (prefers-reduced-motion:reduce){ .marquee-track{animation:none;} .marquee{overflow-x:auto;} }

  .brand-chip{
    border:1px solid var(--line);
    border-radius:6px;
    padding:14px 22px;
    font-family:'Space Grotesk',sans-serif;
    font-weight:700;
    font-size:1rem;
    color:var(--ink);
    background:var(--paper);
    white-space:nowrap;
  }
  /* ---------- griglia marchi rappresentati (home) ---------- */
  .brand-logo-grid {
    margin-top: 22px;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }
  .brand-logo-tile {
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--surface);
    padding: 22px;
    display: flex;
    align-items: center;
    justify-content: center;
    height: 96px;
    transition: transform .2s ease, box-shadow .2s ease, border-color .2s ease;
  }
  .brand-logo-tile img {
    max-height: 46px;
    max-width: 130px;
    width: auto;
    height: auto;
    object-fit: contain;
  }
  .brand-logo-tile:hover {
    transform: scale(1.03);
    border-color: var(--copper);
    box-shadow: 0 4px 18px rgba(193,99,43,0.14);
  }
  @media (max-width: 640px) {
    .brand-logo-grid { grid-template-columns: repeat(2, 1fr); }
  }

  .maps-embed { border-radius: var(--radius); overflow: hidden; border: 1px solid var(--line-soft); }

  .brand-territory-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    margin-top: 28px;
  }
  .bt-card {
    display: flex;
    align-items: center;
    gap: 16px;
    background: var(--surface);
    border: 1px solid var(--line-soft);
    border-radius: var(--radius);
    padding: 16px 18px;
    text-decoration: none;
    color: inherit;
    cursor: pointer;
  }
  .bt-logo {
    flex-shrink: 0;
    width: 80px;
    height: 50px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .bt-logo img {
    max-width: 80px;
    max-height: 40px;
    object-fit: contain;
    width: auto;
    height: auto;
  }
  .bt-name {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 600;
    font-size: 0.88rem;
    color: var(--ink);
  }
  .bt-zone {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.68rem;
    color: var(--petrol);
    letter-spacing: 0.04em;
    margin-top: 4px;
    line-height: 1.4;
  }
  @media (max-width: 920px) {
    .brand-territory-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 560px) {
    .brand-territory-grid { grid-template-columns: 1fr; }
  }
  .brand-note{font-size:0.78rem; color:var(--ink-soft); margin-top:16px;}

  /* ---------- mappa di copertura interattiva (dove operiamo) ---------- */
  #mappa-copertura{scroll-margin-top:90px;}
  .coverage-map-wrap{
    position:relative;
    max-width:560px;
    margin:0 auto;
  }
  .coverage-map{display:block; width:100%; height:auto;}
  .coverage-tooltip{
    position:absolute;
    top:0; left:0;
    z-index:30;
    min-width:150px;
    max-width:210px;
    background:var(--ink);
    color:#fff;
    border-radius:8px;
    padding:12px 14px;
    box-shadow:0 8px 24px rgba(0,0,0,0.2);
    pointer-events:none;
  }
  .coverage-tooltip[hidden]{display:none;}
  .ct-title{
    font-family:'Space Grotesk',sans-serif;
    font-weight:700;
    font-size:0.86rem;
    margin-bottom:8px;
  }
  .ct-brands{display:flex; flex-direction:column; gap:8px;}
  .ct-brands.ct-empty{color:#c7d0d2; font-style:italic; font-size:0.76rem;}
  .ct-brand{display:flex; align-items:center; gap:8px;}
  .ct-brand img{width:24px; height:24px; object-fit:contain; background:#fff; border-radius:4px; padding:2px;}
  .ct-brand span{font-family:'IBM Plex Mono',monospace; font-size:0.68rem; letter-spacing:0.02em;}

  .ref-chip{
    font-family:'IBM Plex Mono',monospace;
    font-size:0.84rem;
    color:var(--ink-soft);
    white-space:nowrap;
    display:flex;
    align-items:center;
    gap:18px;
  }
  .ref-chip::after{content:"·"; color:var(--copper);}
  .ref-chip:last-child::after{content:none;}

  /* etichetta categoria fissa a sinistra di ogni riga referenze */
  .ref-row{display:flex; align-items:center; gap:24px; max-width:var(--maxw); margin:0 auto; padding:0 28px;}
  .ref-row + .ref-row{margin-top:16px;}
  .ref-cat{
    flex:0 0 200px;
    font-family:'IBM Plex Mono',monospace;
    font-size:0.72rem;
    letter-spacing:0.08em;
    text-transform:uppercase;
    color:var(--petrol);
    border-right:1px solid var(--line);
    padding-right:18px;
    white-space:nowrap;
  }
  .ref-row .marquee{flex:1; min-width:0;}

  /* ---------- dove operiamo ---------- */
  .dove{
    display:grid;
    grid-template-columns:1fr 0.85fr;
    gap:48px;
    align-items:center;
  }
  /* ---------- servizi ---------- */
  .servizi-grid{
    display:grid;
    grid-template-columns:repeat(4,1fr);
    gap:16px;
    margin-top:30px;
  }
  .servizio-card{
    background:var(--surface);
    border:1px solid var(--line-soft);
    border-radius:var(--radius);
    padding:22px 20px;
  }
  .servizio-card svg{margin-bottom:14px;}
  .servizio-card h3{font-size:1.14rem; font-weight:600; color:var(--ink); margin-bottom:8px;}
  .servizio-card p{font-size:0.84rem; color:var(--ink-soft); line-height:1.55;}

  /* ---------- anteprima mappa di copertura (home) ---------- */
  .coverage-preview-card{
    display:block;
    background:var(--surface);
    border:1px solid var(--line-soft);
    border-radius:var(--radius);
    overflow:hidden;
    max-width:480px;
    margin:0 auto;
    cursor:pointer;
    transition:filter .2s ease, transform .2s ease;
  }
  .coverage-preview-card img{display:block; width:100%; height:auto;}
  .coverage-preview-card:hover{filter:brightness(1.04); transform:scale(1.01);}

  /* ---------- mission / vision ---------- */
  .mission-statement{font-size:1.18rem; line-height:1.6; max-width:760px; color:var(--ink);}
  .mv-full-toggle{margin-top:18px;}
  .mv-full-toggle > summary{
    cursor:pointer;
    list-style:none;
    font-family:'IBM Plex Mono',monospace;
    font-size:0.72rem;
    letter-spacing:0.06em;
    text-transform:uppercase;
    color:var(--petrol);
    display:inline-flex;
    align-items:center;
    gap:6px;
    user-select:none;
  }
  .mv-full-toggle > summary::-webkit-details-marker{display:none;}
  .mv-full-toggle > summary::before{content:"▸"; transition:transform .2s;}
  .mv-full-toggle[open] > summary::before{transform:rotate(90deg);}
  .mv-full-text{margin-top:16px; max-width:760px;}
  .mv-full-text p{font-size:0.95rem; line-height:1.75; color:var(--ink-soft); margin-top:14px;}
  .mv-full-text p:first-child{margin-top:0;}

  /* ---------- mission & vision preview (home) ---------- */
  .mv-preview-grid{display:grid; grid-template-columns:1fr 1fr; gap:20px; margin-top:30px;}
  .mv-preview-card{background:var(--surface); border:1px solid var(--line-soft); border-radius:var(--radius); padding:26px 24px;}
  .mv-preview-card .ds-key{margin-bottom:10px;}
  .mv-preview-text{font-size:0.92rem; line-height:1.65; color:var(--ink); margin-bottom:14px;}
  @media (max-width:720px){
    .mv-preview-grid{grid-template-columns:1fr;}
  }

  .pillars{
    display:grid;
    grid-template-columns:repeat(3,1fr);
    margin-top:38px;
  }
  .pillar{
    padding:0 26px;
    border-left:1px solid var(--line);
  }
  .pillar:first-child{border-left:none; padding-left:0;}
  .pillar h3{font-size:1.16rem; font-weight:600; margin-bottom:8px; color:var(--ink);}
  .pillar p{font-size:0.86rem; color:var(--ink-soft); line-height:1.55;}

  /* ---------- contatti ---------- */
  .contatti{
    background:var(--ink);
    color:#e9eef0;
    border-radius:16px;
    padding:48px 44px;
    display:grid;
    grid-template-columns:1.1fr 1fr;
    gap:40px;
    align-items:center;
  }
  .contatti h2{color:#fff;}
  .contatti p.lead{color:#aebcc0; margin-top:10px; max-width:420px; line-height:1.6;}
  .contact-list{margin-top:24px; display:grid; gap:12px;}
  .contact-list a, .contact-list span{font-family:'IBM Plex Mono',monospace; font-size:0.86rem; color:#dfe7e8; text-decoration:none;}
  .contact-list a:hover{color:var(--copper);}
  .contatti .btn-primary{background:var(--copper);}
  .contatti .btn-primary:hover{background:#a4501f;}
  .hours{font-size:0.78rem; color:#8fa0a5; margin-top:18px; line-height:1.5;}

  /* ---------- footer ---------- */
  footer { padding: 40px 0 30px; font-size: 0.78rem; color: var(--ink-soft); border-top: 1px solid var(--line); margin-top: 40px; }
  .footer-grid { display: grid; grid-template-columns: 1.4fr 1fr 1fr; gap: 40px; padding-bottom: 28px; }
  .footer-brand { display: flex; align-items: center; gap: 10px; }
  .footer-col-label { font-family: 'IBM Plex Mono', monospace; font-size: 0.65rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--petrol); margin-bottom: 12px; }
  .footer-nav { display: flex; flex-direction: column; gap: 8px; }
  .footer-nav a { color: var(--ink-soft); text-decoration: none; font-size: 0.82rem; }
  .footer-nav a:hover { color: var(--petrol); }
  .footer-contacts { display: flex; flex-direction: column; gap: 6px; }
  .footer-contacts a, .footer-contacts span { font-family: 'IBM Plex Mono', monospace; font-size: 0.75rem; color: var(--ink-soft); text-decoration: none; }
  .footer-contacts a:hover { color: var(--copper); }
  .footer-bottom { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 14px 20px; padding-top: 18px; border-top: 1px solid var(--line-soft); font-size: 0.72rem; }
  .footer-powered { display: flex; align-items: center; gap: 10px; }
  .footer-powered-label { font-family: 'IBM Plex Mono', monospace; font-size: 0.66rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--ink-soft); }
  .footer-powered-badge { display: inline-flex; align-items: center; justify-content: center; background: var(--copper); border-radius: 8px; padding: 3px 5px; }
  .footer-powered-logo { height: 26px; width: auto; display: block; border-radius: 5px; }
  .footer-legal { display: flex; flex-direction: column; gap: 4px; text-align: right; }
  @media (max-width: 720px) {
    .footer-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 480px) {
    .footer-grid { grid-template-columns: 1fr; gap: 24px; }
  }

  /* ---------- responsive ---------- */
  @media (max-width:920px){
    .hero-grid{grid-template-columns:1fr;}
    .hero-logo-stage{max-width:240px; margin:8px auto 0;}
    .datasheet .wrap{grid-template-columns:repeat(2,1fr);}
    .ds-item:nth-child(2n){border-right:none;}
    .servizi-grid{grid-template-columns:repeat(2,1fr);}
    .dove{grid-template-columns:1fr;}
    .pillars{grid-template-columns:1fr; gap:18px;}
    .pillar{border-left:none; padding-left:0; border-top:1px solid var(--line); padding-top:18px;}
    .pillar:first-child{border-top:none; padding-top:0;}
    .contatti{grid-template-columns:1fr; padding:36px 26px;}
    .nav{flex-wrap:wrap;}
    .nav-toggle{display:flex; order:3;}
    .nav-links{
      display:none;
      order:4;
      flex-direction:column;
      width:100%;
      gap:0;
      margin-top:14px;
      padding-top:10px;
      border-top:1px solid rgba(255,255,255,0.25);
    }
    .nav-toggle-input:checked ~ .nav-links{display:flex;}
    .nav-links li{width:100%;}
    .nav-links a{display:block; padding:12px 2px; border-bottom:1px solid rgba(255,255,255,0.2); font-size:0.94rem;}
    .nav-links li:last-child a{border-bottom:none;}
    .nav-tel{display:none;}
    .nav-tel-mobile{display:block;}
    .nav-tel-mobile a{
      font-size:1rem;
      padding:14px 0;
      color:#fff;
      font-weight:600;
    }
  }
  @media (max-width:640px){
    .ref-row{flex-direction:column; align-items:flex-start; gap:8px;}
    .ref-cat{flex:0 0 auto; border-right:none; padding-right:0;}
  }
  @media (max-width:560px){
    .hero h1{font-size:2.1rem;}
    .team-grid{grid-template-columns:repeat(2,1fr);}
    .servizi-grid{grid-template-columns:1fr;}
  }

  /* ===== Sezione referenze in home ===== */
  .section-affida { padding: 60px 0; background: var(--surface); border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); }

  /* ===== Referenze page: chip-grid per categoria ===== */
  .ref-section-header { margin-bottom: 28px; display:flex; align-items:baseline; flex-wrap:wrap; gap:10px 18px; }
  .ref-section-cat {
    display: inline-block;
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: clamp(2rem, 3.6vw, 2.9rem);
    line-height: 1.08;
    letter-spacing: -0.02em;
    color: var(--petrol);
    border-left: 4px solid var(--copper);
    padding-left: 18px;
  }
  .ref-name-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }
  .ref-name-chip {
    font-family: 'IBM Plex Sans', sans-serif;
    font-size: 0.84rem;
    color: var(--ink);
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: 6px;
    padding: 8px 14px;
    transition: border-color .2s, color .2s, transform .2s;
  }
  .ref-name-chip:hover { border-color: var(--petrol); color: var(--petrol); transform: translateY(-1px); }

  /* ===== Upgrade grafico generale ===== */
  /* card hover universale con micro-sollevamento */
  .servizio-card, .team-card, .founder-card, .bt-card {
    transition: border-color .2s ease, box-shadow .2s ease, transform .2s ease;
  }
  .servizio-card:hover, .team-card:hover, .bt-card:hover {
    border-color: var(--petrol);
    box-shadow: 0 6px 20px rgba(45,85,99,0.10);
    transform: translateY(-2px);
  }
  @media (prefers-reduced-motion:reduce){
    .servizio-card:hover, .team-card:hover, .bt-card:hover,
    .ref-name-chip:hover, .brand-logo-tile:hover { transform: none; }
  }

  /* ===== Divisione sezioni: fasce di fondo (derivazioni della palette) ===== */
  /* transizioni nette e volute: filo tecnico tra una fascia e l'altra */
  .section--surface { background: var(--surface); border-top:1px solid var(--line-soft); border-bottom:1px solid var(--line-soft); }
  .section--tint { background: var(--tint); border-top:1px solid var(--line); border-bottom:1px solid var(--line); }
  /* blocco chiave a contrasto forte (riuso dello stile del blocco contatti):
     accento copper in alto + reticolo scuro in overlay, non un rettangolo piatto */
  .section--petrol {
    background-color: var(--petrol);
    background-image:
      repeating-linear-gradient(0deg, rgba(0,0,0,0.05) 0 1px, transparent 1px 30px),
      repeating-linear-gradient(90deg, rgba(0,0,0,0.045) 0 1px, transparent 1px 30px);
    color: var(--paper);
    border-top:2px solid var(--copper);
    border-bottom:1px solid var(--petrol-deep);
  }
  .section--petrol h2, .section--petrol h3 { color: #fff; }
  .section--petrol .eyebrow { color: var(--paper); }
  .section--petrol .eyebrow::before { background: var(--copper); }
  .section--petrol .mission-statement { color: #fff; }
  .section--petrol .pillar { border-left-color: rgba(255,255,255,0.22); }
  .section--petrol .pillar h3 { color: #fff; }
  .section--petrol .pillar p { color: rgba(238,242,241,0.82); }
  .section--petrol .mv-full-toggle > summary,
  .section--petrol .card-cue { color: #e7c8b4; }
  .section--petrol .mv-full-text p { color: rgba(238,242,241,0.85); }
  @media (max-width:920px){
    .section--petrol .pillar { border-top-color: rgba(255,255,255,0.22); }
  }

  @media (max-width: 560px) {
    .footer-bottom { flex-direction: column; align-items: flex-start; gap: 12px; }
    .footer-legal { text-align: left; }
  }

  /* ===== Blocchi split foto/testo (asimmetria controllata) ===== */
  .split{
    display:grid;
    grid-template-columns:1fr 1fr;
    gap:clamp(28px,5vw,56px);
    align-items:center;
  }
  .split--wide-text{grid-template-columns:1.15fr 0.85fr;}
  .split--wide-media{grid-template-columns:0.85fr 1.15fr;}
  .split-figure{margin:0; position:relative;}
  .split-figure img{
    display:block; width:100%; height:100%;
    aspect-ratio:4/3; object-fit:cover;
    border:1px solid var(--line-soft);
    border-radius:var(--radius);
  }
  /* cornice tecnica: sottile riquadro copper sfalsato dietro la foto */
  .split-figure--framed::before{
    content:""; position:absolute; inset:14px -14px -14px 14px;
    border:1.5px solid var(--copper); border-radius:var(--radius);
    z-index:-1; opacity:0.5;
  }
  .split-figure figcaption{
    margin-top:10px;
    font-family:'IBM Plex Mono',monospace; font-size:0.72rem;
    letter-spacing:0.06em; text-transform:uppercase; color:var(--ink-soft);
    display:flex; align-items:center; gap:8px;
  }
  .split-figure figcaption::before{content:""; width:16px; height:2px; background:var(--copper); flex-shrink:0;}
  @media (max-width:760px){
    .split, .split--wide-text, .split--wide-media{grid-template-columns:1fr; gap:24px;}
    .split--reverse .split-media{order:-1;}
    .split-figure--framed::before{inset:10px -8px -10px 8px;}
  }

  /* ===== Pannello dati mono (riempie il lato libero di un testo) ===== */
  .data-panel{
    background:var(--surface);
    border:1px solid var(--line);
    border-left:3px solid var(--copper);
    border-radius:var(--radius);
    padding:22px 24px;
  }
  .section--petrol .data-panel{
    background:rgba(255,255,255,0.05);
    border-color:rgba(255,255,255,0.16);
    border-left-color:var(--copper);
  }
  .data-panel-row{display:flex; justify-content:space-between; gap:16px; align-items:baseline; padding:11px 0; border-top:1px solid var(--line-soft);}
  .data-panel-row:first-child{border-top:none;}
  .section--petrol .data-panel-row{border-top-color:rgba(255,255,255,0.12);}
  .data-panel-k{font-family:'IBM Plex Mono',monospace; font-size:0.72rem; letter-spacing:0.06em; text-transform:uppercase; color:var(--ink-soft);}
  .section--petrol .data-panel-k{color:rgba(238,242,241,0.7);}
  .data-panel-v{font-family:'IBM Plex Mono',monospace; font-size:0.94rem; font-weight:600; color:var(--petrol); text-align:right;}
  .section--petrol .data-panel-v{color:#fff;}
  /* lista obiettivi: il "+" richiama il "Più" del testo Vision */
  .plus-list{list-style:none; margin:0; padding:0;}
  .plus-list li{display:flex; align-items:baseline; gap:12px; padding:13px 0; border-top:1px solid var(--line-soft); font-family:'Space Grotesk',sans-serif; font-weight:600; font-size:1.02rem; color:var(--ink);}
  .plus-list li:first-child{border-top:none;}
  .plus-list li::before{content:"+"; color:var(--copper); font-family:'IBM Plex Mono',monospace; font-weight:700; font-size:1.15rem; line-height:1;}

  /* ===== Servizi preview (home): bento con tessera featured ===== */
  .servizi-preview-grid{
    display:grid;
    grid-template-columns:repeat(3,1fr);
    gap:16px;
    margin-top:30px;
  }
  .servizio-card--featured{
    grid-column:1 / -1;
    display:grid;
    grid-template-columns:1fr 1.05fr;
    gap:0;
    padding:0;
    overflow:hidden;
    align-items:stretch;
  }
  .sc-feat-body{padding:26px 30px; display:flex; flex-direction:column; justify-content:center;}
  .sc-feat-body h3{font-size:1.28rem;}
  .sc-feat-body p{font-size:0.9rem; margin-bottom:0;}
  .sc-feat-media{position:relative; min-height:210px; background:var(--tint);}
  .sc-feat-media img{position:absolute; inset:0; width:100%; height:100%; object-fit:cover;}
  @media (max-width:720px){
    .servizi-preview-grid{grid-template-columns:1fr 1fr;}
    .servizio-card--featured{grid-template-columns:1fr;}
    .sc-feat-media{min-height:180px; order:-1;}
  }
  @media (max-width:480px){
    .servizi-preview-grid{grid-template-columns:1fr;}
  }

  /* ===== Gallery Centro Didattico Formativo (chi-siamo): feature vera ===== */
  .cdf-gallery{
    display:grid;
    grid-template-columns:repeat(4,1fr);
    grid-template-rows:clamp(150px,22vw,230px) clamp(150px,22vw,230px);
    gap:14px;
    margin-top:8px;
  }
  .cdf-item{margin:0; position:relative; overflow:hidden; border:1px solid var(--line-soft); border-radius:var(--radius); background:var(--surface);}
  .cdf-item img{display:block; width:100%; height:100%; object-fit:cover; transition:transform .5s ease;}
  .cdf-item:hover img{transform:scale(1.04);}
  .cdf-item--lead{grid-column:1 / 3; grid-row:1 / 3;}
  .cdf-item--wide{grid-column:3 / 5;}
  .cdf-item figcaption{
    position:absolute; left:0; right:0; bottom:0;
    padding:18px 14px 9px;
    font-family:'IBM Plex Mono',monospace; font-size:0.68rem; letter-spacing:0.06em;
    text-transform:uppercase; color:#fff;
    background:linear-gradient(0deg, rgba(22,36,42,0.82), transparent);
  }
  @media (prefers-reduced-motion:reduce){ .cdf-item img{transition:none;} }
  @media (max-width:640px){
    .cdf-gallery{grid-template-columns:1fr 1fr; grid-template-rows:none;}
    .cdf-item{aspect-ratio:4/3;}
    .cdf-item--lead{grid-column:1 / -1; grid-row:auto; aspect-ratio:16/9;}
    .cdf-item--wide{grid-column:1 / -1; aspect-ratio:16/9;}
  }

  /* ===== Banner intro con foto (servizi) ===== */
  .intro-banner{align-items:stretch;}
  .intro-banner .split-figure img{aspect-ratio:auto; min-height:100%;}
  @media (max-width:760px){
    .intro-banner .split-figure img{aspect-ratio:16/9; min-height:0;}
  }

  /* ===== Mosaico Centro Didattico in home (lead gruppo + scatto di supporto) =====
     La galleria si allunga fino all'altezza della colonna testo (niente vuoti):
     due foto in mosaico verticale con didascalie leggibili in overlay. */
  .cdf-home-split{align-items:stretch;}
  /* il testo si centra verticalmente: niente spazio vuoto in fondo alla colonna */
  .cdf-home-split .split-text{align-self:center;}
  .cdf-home-gallery{
    display:grid;
    grid-template-rows:1.5fr 1fr;
    gap:14px;
    height:100%;
    min-height:360px;
  }
  .cdf-fig{
    position:relative; margin:0; min-height:0;
    overflow:hidden;
    border:1px solid var(--line-soft);
    border-radius:var(--radius);
    background:var(--surface);
  }
  /* immagini in overlay assoluto: riempiono sempre la tessera senza gonfiare la riga */
  .cdf-fig img{position:absolute; inset:0; display:block; width:100%; height:100%; object-fit:cover;}
  .cdf-home-lead img{object-position:center 42%;}
  .cdf-fig figcaption{
    position:absolute; left:0; right:0; bottom:0; z-index:1;
    padding:20px 16px 11px;
    font-family:'IBM Plex Mono',monospace; font-size:0.68rem;
    letter-spacing:0.06em; text-transform:uppercase; color:#fff;
    background:linear-gradient(0deg, rgba(22,36,42,0.85), rgba(22,36,42,0.4) 55%, transparent);
  }
  @media (max-width:760px){
    .cdf-home-split .split-text{align-self:stretch;}
    .cdf-home-gallery{grid-template-rows:none; height:auto; min-height:0;}
    .cdf-fig{aspect-ratio:16/9;}
  }

  /* ===== Mappa copertura affiancata a legenda/dati (dove operiamo) ===== */
  .coverage-split{
    display:grid;
    grid-template-columns:1.05fr 0.95fr;
    gap:clamp(28px,5vw,52px);
    align-items:start;
  }
  .coverage-split .coverage-map-wrap{margin:0; max-width:520px;}
  .map-swatch{width:20px; height:20px; border-radius:5px; flex-shrink:0; border:1px solid rgba(0,0,0,0.08);}
  .map-legend-sub{font-family:'IBM Plex Mono',monospace; font-size:0.68rem; color:var(--ink-soft); letter-spacing:0.03em; margin-top:2px;}
  .coverage-hint{font-size:0.78rem; color:var(--ink-soft); margin-top:14px; line-height:1.55; text-align:center;}
  .coverage-hint span{color:var(--copper); font-weight:600;}
  /* scheda di copertura: legenda regioni + stat in un unico blocco tecnico */
  .coverage-card{
    background:var(--surface);
    border:1px solid var(--line);
    border-top:2px solid var(--petrol);
    border-radius:var(--radius);
    padding:22px 24px;
  }
  .coverage-card-head{
    font-family:'IBM Plex Mono',monospace;
    font-size:0.7rem; letter-spacing:0.12em; text-transform:uppercase;
    color:var(--ink-soft); margin-bottom:16px;
    display:flex; align-items:center; gap:10px;
  }
  .coverage-card-head::before{content:""; width:16px; height:2px; background:var(--copper);}
  .coverage-region{display:flex; align-items:flex-start; gap:12px; padding:12px 0; border-top:1px solid var(--line-soft);}
  .coverage-region:first-of-type{border-top:none; padding-top:0;}
  .coverage-region-body{min-width:0;}
  .coverage-region .map-swatch{margin-top:2px;}
  .coverage-region-name{font-family:'Space Grotesk',sans-serif; font-weight:600; font-size:0.95rem; color:var(--ink); display:flex; align-items:baseline; gap:8px; flex-wrap:wrap;}
  .coverage-region-count{font-family:'IBM Plex Mono',monospace; font-size:0.7rem; font-weight:600; letter-spacing:0.04em; color:var(--copper);}
  .coverage-card-divider{height:1px; background:var(--line); margin:16px 0;}
  .coverage-card .data-panel{margin:0; background:none; border:none; border-radius:0; padding:0;}
  @media (max-width:820px){
    .coverage-split{grid-template-columns:1fr; gap:28px;}
    .coverage-split .coverage-map-wrap{max-width:520px; margin:0 auto;}
  }

  /* bottoni più raffinati */
  .btn {
    transition: background .2s ease, border-color .2s ease, color .2s ease;
    letter-spacing: 0.01em;
  }

  /* details/summary "Leggi tutto" */
  .expand-block { margin-top: 12px; }
  .expand-block summary {
    cursor: pointer;
    list-style: none;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.75rem;
    color: var(--petrol);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    user-select: none;
  }
  .expand-block summary::-webkit-details-marker { display: none; }
  .expand-block summary::before { content: "▸"; transition: transform .2s; }
  .expand-block[open] summary::before { transform: rotate(90deg); }
  .expand-block[open] summary { color: var(--ink-soft); }
  .expand-block > p, .expand-block > div { margin-top: 14px; }

  /* ===== Placeholder foto generico ===== */
  .photo-ph{
    background:
      repeating-linear-gradient(45deg, rgba(45,85,99,0.05) 0 10px, transparent 10px 20px),
      var(--paper);
    border:1.5px dashed var(--line);
    border-radius:var(--radius);
    display:flex;
    flex-direction:column;
    align-items:center;
    justify-content:center;
    gap:8px;
    color:var(--ink-soft);
    font-family:'IBM Plex Mono',monospace;
    font-size:0.72rem;
    letter-spacing:0.08em;
    text-transform:uppercase;
    text-align:center;
    padding:18px;
  }
  .photo-ph svg{opacity:0.55;}

  /* home: chi siamo a due colonne */
  .chisiamo-home{
    display:grid;
    grid-template-columns:1.1fr 0.9fr;
    gap:48px;
    align-items:center;
  }
  .chisiamo-home .photo-ph{aspect-ratio:3/2;}
  .chisiamo-home-photo{margin:0; aspect-ratio:3/2; overflow:hidden; border:1px solid var(--line-soft); border-radius:var(--radius); background:var(--surface);}
  .chisiamo-home-photo img{display:block; width:100%; height:100%; object-fit:cover;}
  @media (max-width:760px){ .chisiamo-home{grid-template-columns:1fr;} }

  /* dove operiamo: placeholder mappa */
  .map-ph{min-height:320px; height:100%;}
  .map-ph .map-addr{color:var(--ink); font-size:0.82rem; text-transform:none; letter-spacing:0; margin-top:6px; line-height:1.5;}

  /* dove operiamo: foto reale della sede */
  .sede-figure{margin:0;}
  .sede-figure img{
    display:block; width:100%; height:100%;
    aspect-ratio:4/3; object-fit:cover;
    border:1px solid var(--line-soft);
    border-radius:var(--radius);
  }
  .sede-figure .map-addr{color:var(--ink); font-size:0.82rem; text-transform:none; letter-spacing:0; margin-top:10px; line-height:1.5;}

  /* chi-siamo: galleria showroom a scorrimento orizzontale */
  .showroom{padding-top:0;}
  .showroom .eyebrow{margin-bottom:18px;}
  .showroom-scroll{
    display:flex; gap:18px;
    overflow-x:auto;
    scroll-snap-type:x mandatory;
    -webkit-overflow-scrolling:touch;
    padding-bottom:8px;
    mask-image:linear-gradient(90deg, transparent, #000 4%, #000 96%, transparent);
  }
  .showroom-scroll::-webkit-scrollbar{height:6px;}
  .showroom-scroll::-webkit-scrollbar-thumb{background:var(--line); border-radius:3px;}
  .showroom-card{
    flex:0 0 clamp(240px, 42%, 380px);
    scroll-snap-align:start;
  }
  .showroom-card figure{
    margin:0; overflow:hidden;
    border:1px solid var(--line-soft);
    border-radius:var(--radius);
    background:var(--surface);
  }
  .showroom-card img{
    display:block; width:100%; aspect-ratio:4/3; object-fit:cover;
    transition:transform 0.5s ease;
  }
  .showroom-card:hover img{transform:scale(1.03);}
  .showroom-card figcaption{margin-top:8px;}
  @media (prefers-reduced-motion:reduce){
    .showroom-card img{transition:none;}
  }

  /* ===== servizi: flex + pannello sotto griglia ===== */
  .servizi-flex{
    display:flex;
    flex-wrap:wrap;
    gap:16px;
    margin-top:30px;
    justify-content:center;
  }
  .servizi-flex .servizio-card{
    flex:0 1 calc((100% - 48px) / 4);
    text-align:left;
    cursor:pointer;
    transition:border-color .4s ease, box-shadow .4s ease, background .4s ease;
  }
  .card-cue{
    margin-top:12px;
    font-family:'IBM Plex Mono',monospace;
    font-size:0.72rem;
    letter-spacing:0.06em;
    text-transform:uppercase;
    color:var(--petrol);
    display:inline-flex;
    align-items:center;
    gap:6px;
    text-decoration:none;
  }
  .card-cue::before{content:"▸"; transition:transform .2s;}
  .card-cue:hover{color:var(--copper);}
  .servizio-card.flash{
    border-color:var(--copper);
    box-shadow:0 0 0 3px rgba(193,99,43,0.22);
    background:#fbf1ea;
  }
  @media (max-width:920px){
    .servizi-flex .servizio-card{flex-basis:calc((100% - 16px) / 2);}
  }
  @media (max-width:560px){
    .servizi-flex .servizio-card{flex-basis:100%;}
  }

  /* ===== Modale servizio (Direzione A — Schema Tecnico) ===== */
  .servizio-modal-overlay{
    position:fixed;
    inset:0;
    z-index:1000;
    display:flex;
    align-items:center;
    justify-content:center;
    padding:24px;
    background:rgba(22,36,42,0.55);
    opacity:0;
    visibility:hidden;
    pointer-events:none;
    transition:opacity .18s ease, visibility 0s linear .18s;
  }
  .servizio-modal-overlay.is-open{
    opacity:1;
    visibility:visible;
    pointer-events:auto;
    transition:opacity .18s ease;
  }
  .servizio-modal{
    position:relative;
    width:100%;
    max-width:620px;
    max-height:82vh;
    overflow-y:auto;
    background:var(--paper);
    border-radius:12px;
    border-top:4px solid var(--copper);
    padding:36px 40px;
    transform:scale(0.96);
    transition:transform .18s ease;
  }
  .servizio-modal-overlay.is-open .servizio-modal{
    transform:scale(1);
  }
  .servizio-modal h3{
    font-family:'Space Grotesk', sans-serif;
    font-weight:500;
    color:var(--ink);
    font-size:1.25rem;
    margin:0 32px 16px 0;
  }
  .servizio-modal p{
    font-family:'IBM Plex Sans', sans-serif;
    color:var(--petrol);
    font-size:0.95rem;
    line-height:1.75;
    margin:0;
  }
  .servizio-modal-close{
    position:absolute;
    top:16px;
    right:16px;
    width:32px;
    height:32px;
    display:flex;
    align-items:center;
    justify-content:center;
    border:none;
    border-radius:6px;
    background:transparent;
    color:var(--ink);
    cursor:pointer;
    transition:background .15s ease;
  }
  .servizio-modal-close:hover{background:rgba(45,85,99,0.08);}
  @media (max-width:560px){
    .servizio-modal{padding:28px 24px;}
  }

  /* ===== Referenze: blocchi con colore differenziato ===== */
  section.ref-block{padding:48px 0;}
  section.ref-block .ref-section-cat{border-left-color:var(--rb-accent); color:var(--rb-accent);}
  section.ref-block .ref-name-chip{background:var(--rb-chip-bg); border-color:var(--rb-accent);}
  section.ref-block .ref-name-chip:hover{border-color:var(--rb-accent); color:var(--rb-accent);}
  section.ref-block--hotellerie{ --rb-accent:#b8860b; --rb-chip-bg:#fffaf0; background:#fdf6ec; }
  section.ref-block--sanita{ --rb-accent:#1a6e8a; --rb-chip-bg:#f4fafd; background:#edf5fb; }
  section.ref-block--industria{ --rb-accent:#4a5568; --rb-chip-bg:#f7f8fa; background:#eef0f3; }

  /* ===== Transizioni di pagina: linee che formano il logo ===== */
  /* Spegne del tutto l'animazione di default della View Transitions API
     (Safari/Chrome): la transizione la gestiamo solo noi con l'overlay. */
  ::view-transition-group(root),
  ::view-transition-image-pair(root),
  ::view-transition-old(root),
  ::view-transition-new(root){ animation:none !important; mix-blend-mode:normal; }
  #tc-transition{position:fixed; inset:0; z-index:9999; pointer-events:none;}
  #tc-veil{
    position:absolute; inset:0;
    /* quasi opaco: durante la transizione lo scambio della pagina avviene
       nascosto sotto il velo, così non si vede "caricare due volte" */
    background:rgba(238,242,241,0.97);
    backdrop-filter:blur(10px);
    -webkit-backdrop-filter:blur(10px);
    opacity:0;
  }
  #tc-transition-svg{position:absolute; inset:0; width:100%; height:100%; display:block; overflow:visible;}
  /* Le linee del logo (centerline estratte da svglogo.svg, in
     /images/logo-lines.svg): ogni <path> è una linea che si "disegna" da
     sinistra via stroke-dashoffset, poi si cancella verso destra. */
  #tc-lines path{
    fill:none; stroke:var(--copper); stroke-width:2.4;
    stroke-linecap:round; stroke-linejoin:round;
    vector-effect:non-scaling-stroke;
  }
  @media (prefers-reduced-motion:reduce){
    #tc-transition{display:none;}
  }
</style>
<script type="application/ld+json">{"@context":"https://schema.org","@type":"Organization","name":"Tecno Consult Srl","url":"https://tecnoconsult-srl.it","logo":"https://tecnoconsult-srl.it/images/tecnoconsult-logo.png","address":{"@type":"PostalAddress","streetAddress":"Via Barcis 2","addressLocality":"San Donà di Piave","postalCode":"30027","addressRegion":"VE","addressCountry":"IT"},"telephone":"+390421512000","email":"info@tecnoconsult-srl.it"}</script>
</head>
<body>
  <div id="tc-transition" transition:persist aria-hidden="true">
    <div id="tc-veil"></div>
    <svg id="tc-transition-svg"><g id="tc-lines"></g></svg>
  </div>
  <Header />
  <slot />
  <Footer />

  <script>
    function initReveal() {
      const els = Array.from(document.querySelectorAll('.reveal'));
      if (!els.length) return;
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        els.forEach((el) => el.classList.add('is-visible'));
        return;
      }
      const obs = new IntersectionObserver((entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add('is-visible');
            obs.unobserve(e.target);
          }
        });
      }, { threshold: 0.15 });
      els.forEach((el) => obs.observe(el));
    }
    document.addEventListener('astro:page-load', initReveal);

    function initPipeDividers() {
      const paths = Array.from(document.querySelectorAll<SVGPathElement>('.pipe-divider path'));
      if (!paths.length) return;
      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      paths.forEach((path) => {
        const length = path.getTotalLength();
        path.style.strokeDasharray = String(length);
        path.style.strokeDashoffset = reduceMotion ? '0' : String(length);
      });
      if (reduceMotion) return;

      const obs = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const path = entry.target as SVGPathElement;
            path.style.transition = 'stroke-dashoffset 700ms ease-in-out';
            path.style.strokeDashoffset = '0';
            obs.unobserve(path);
          }
        });
      }, { threshold: 0.3 });
      paths.forEach((path) => obs.observe(path));
    }
    document.addEventListener('astro:page-load', initPipeDividers);

    function initPageTransition() {
      const overlay = document.getElementById('tc-transition');
      const veil = document.getElementById('tc-veil');
      const svg = document.getElementById('tc-transition-svg');
      const linesG = document.getElementById('tc-lines');
      if (!overlay || !svg || !linesG || overlay.dataset.tcInit || window.__tcBound) return;
      overlay.dataset.tcInit = '1';
      window.__tcBound = true;   // i listener si agganciano una volta sola

      // Linee del logo VERO: centerline estratte da svglogo.svg e salvate in
      // /images/logo-lines.svg (34 tracciati-stroke aperti). Ogni linea si
      // DISEGNA da sinistra (stroke-dashoffset L->0) e poi si CANCELLA verso
      // destra (0 -> -L), sfalsate per posizione orizzontale. Nessuna geometria
      // inventata: sono le stesse linee del logo, solo come centerline.
      let lineDefs = null;        // [{ d, fx }]  fx = x minima normalizzata 0..1
      let vbW = 1, vbH = 1;
      fetch('/images/logo-lines.svg')
        .then((r) => r.text())
        .then((txt) => {
          const doc = new DOMParser().parseFromString(txt, 'image/svg+xml');
          const root = doc.querySelector('svg');
          const vb = (root && root.getAttribute('viewBox') || '0 0 1000 1000').split(/\s+/).map(Number);
          vbW = vb[2] || 1000; vbH = vb[3] || 1000;
          lineDefs = Array.from(doc.querySelectorAll('path')).map((p) => {
            const d = p.getAttribute('d') || '';
            const nums = d.match(/-?\d+(?:\.\d+)?/g) || [];
            let minx = Infinity;
            for (let i = 0; i < nums.length; i += 2) minx = Math.min(minx, parseFloat(nums[i]));
            return { d, fx: (isFinite(minx) ? minx : 0) / vbW };
          });
        })
        .catch(() => {});

      // Tempi (ms). L'ingresso è awaited dal loader, quindi tenuto contenuto.
      const SPREAD_IN = 430, DRAW_IN = 380, JIT_IN = 90, HOLD_MS = 180;
      const SPREAD_OUT = 430, DRAW_OUT = 430, JIT_OUT = 90;
      const NS = 'http://www.w3.org/2000/svg';
      let items = [];
      let cleanupTimer = null;
      let running = false;   // evita che una fase parta due volte sovrapposte

      function reduceMotion() { return window.matchMedia('(prefers-reduced-motion: reduce)').matches; }

      // annulla ogni animazione ancora attiva sul velo (persiste tra le pagine:
      // senza questo le animazioni fill:forwards si accumulerebbero e darebbero
      // micro-sfarfallii) e sulle linee
      function cancelAll() {
        if (veil.getAnimations) veil.getAnimations().forEach((a) => a.cancel());
        items.forEach((o) => { if (o.el.getAnimations) o.el.getAnimations().forEach((a) => a.cancel()); });
      }

      // costruisce i <path> centrati/scalati nel viewport, nascosti (dashoffset=L)
      function build() {
        if (!lineDefs) return false;
        if (cleanupTimer) { clearTimeout(cleanupTimer); cleanupTimer = null; }
        cancelAll();
        const W = window.innerWidth, H = window.innerHeight;
        svg.setAttribute('viewBox', '0 0 ' + W + ' ' + H);
        linesG.innerHTML = '';
        const size = Math.min(W, H) * 0.5;
        const scale = size / Math.max(vbW, vbH);
        const g = document.createElementNS(NS, 'g');
        g.setAttribute('transform',
          'translate(' + (W / 2) + ',' + (H / 2) + ') scale(' + scale + ') ' +
          'translate(' + (-vbW / 2) + ',' + (-vbH / 2) + ')');
        linesG.appendChild(g);
        items = lineDefs.map((def) => {
          const el = document.createElementNS(NS, 'path');
          el.setAttribute('d', def.d);
          g.appendChild(el);
          const L = el.getTotalLength() || 1;
          el.style.strokeDasharray = L;
          el.style.strokeDashoffset = L;
          return { el, L, fx: def.fx };
        });
        return items.length > 0;
      }

      // ENTRATA: ogni linea si disegna da SINISTRA; sfalsate per x.
      function playEnterPhase() {
        return new Promise((resolve) => {
          if (reduceMotion() || running || !build()) { resolve(); return; }
          running = true;
          veil.style.transition = 'none';
          veil.style.opacity = '0';
          void svg.getBoundingClientRect();

          let maxIn = 0;
          items.forEach((o) => {
            const delay = o.fx * SPREAD_IN + Math.random() * JIT_IN;
            const dur = DRAW_IN + Math.random() * 140;
            maxIn = Math.max(maxIn, delay + dur);
            o.el.animate(
              [{ strokeDashoffset: o.L }, { strokeDashoffset: 0 }],
              { duration: dur, delay: delay, easing: 'cubic-bezier(.3,0,.3,1)', fill: 'both' }
            );
          });
          veil.animate([{ opacity: 0 }, { opacity: 1 }], { duration: maxIn * 0.6, easing: 'ease', fill: 'forwards' });
          setTimeout(resolve, maxIn + HOLD_MS);
        });
      }

      // USCITA: ogni linea si cancella scorrendo verso DESTRA (offset 0 -> -L).
      function playExitPhase() {
        running = false;
        if (reduceMotion() || !items.length) { linesG.innerHTML = ''; return; }
        let maxOut = 0;
        items.forEach((o) => {
          const delay = o.fx * SPREAD_OUT + Math.random() * JIT_OUT;
          const dur = DRAW_OUT + Math.random() * 140;
          maxOut = Math.max(maxOut, delay + dur);
          o.el.animate(
            [{ strokeDashoffset: 0 }, { strokeDashoffset: -o.L }],
            { duration: dur, delay: delay, easing: 'cubic-bezier(.5,0,.4,1)', fill: 'both' }
          );
        });
        veil.animate([{ opacity: 1 }, { opacity: 0 }], { duration: maxOut * 0.85, easing: 'ease', fill: 'forwards' });
        cleanupTimer = setTimeout(() => { linesG.innerHTML = ''; items = []; cleanupTimer = null; }, maxOut + 80);
      }

      document.addEventListener('astro:before-preparation', (event) => {
        const originalLoader = event.loader;
        event.loader = async () => {
          await playEnterPhase();
          await originalLoader();
        };
      });
      document.addEventListener('astro:after-swap', playExitPhase);
    }
    initPageTransition();
  </script>
</body>
