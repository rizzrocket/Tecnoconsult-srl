            const anim = el.animate(
              [
                { transform: 'translate(' + (-OFFSET_X) + 'px, ' + (dir * amp * 0.9) + 'px) rotate(' + (dir * -2.5) + 'deg)', opacity: 0 },
                { transform: 'translate(' + (-OFFSET_X * 0.72) + 'px, ' + (-dir * amp) + 'px) rotate(' + (dir * 2) + 'deg)', opacity: 0.7, offset: 0.22 },
                { transform: 'translate(' + (-OFFSET_X * 0.44) + 'px, ' + (dir * amp * 0.7) + 'px) rotate(' + (dir * -1.5) + 'deg)', opacity: 1, offset: 0.45 },
                { transform: 'translate(' + (-OFFSET_X * 0.2) + 'px, ' + (-dir * amp * 0.4) + 'px) rotate(' + (dir * 0.9) + 'deg)', offset: 0.68 },
                { transform: 'translate(' + (-OFFSET_X * 0.06) + 'px, ' + (dir * amp * 0.15) + 'px) rotate(' + (dir * -0.35) + 'deg)', offset: 0.86 },
                { transform: 'translate(0px, 0px) rotate(0deg)', opacity: 1 }
              ],
              { duration: ENTER_MS, delay, easing: 'cubic-bezier(.16,.8,.4,1)', fill: 'forwards' }
            );
            els.push({ el, delay, dir, amp, anim });
          });

          svg.__tcEls = els;
          veil.animate([{ opacity: 0 }, { opacity: 1 }], { duration: ENTER_MS * 0.6, easing: 'ease', fill: 'forwards' });

          const lastFinish = ENTER_MS + ENTER_SPAN;
          Promise.all(els.map((t) => t.anim.finished)).then(() => {
            setTimeout(resolve, HOLD_MS);
          }).catch(() => setTimeout(resolve, lastFinish + HOLD_MS));
        });
      }

      function playExitPhase() {
        if (reduceMotion()) { logoWrap.innerHTML = ''; return; }
        const els = svg.__tcEls || [];
        const W = window.innerWidth, H = window.innerHeight;
        const OFFSET_X = W * 0.65;
        const AMP_FALLBACK = Math.max(14, H * 0.03);

        veil.animate([{ opacity: 1 }, { opacity: 0 }], { duration: EXIT_MS * 0.8, easing: 'ease', fill: 'forwards' });

        els.forEach((tr) => {
          // stesso ordine sinistra→destra dell'entrata: le linee riprendono a
          // scorrere verso destra ondulando come serpenti (ampiezza crescente
          // mentre accelerano) e scivolano fuori dallo schermo sfumando
          const exitDelay = tr.delay * (EXIT_SPAN / ENTER_SPAN);
          const dir = tr.dir || 1;
          const amp = tr.amp || AMP_FALLBACK;
          const anim = tr.el.animate(
            [
              { transform: 'translate(0px, 0px) rotate(0deg)', opacity: 1 },
              { transform: 'translate(' + (OFFSET_X * 0.07) + 'px, ' + (-dir * amp * 0.2) + 'px) rotate(' + (dir * 0.5) + 'deg)', offset: 0.18 },
              { transform: 'translate(' + (OFFSET_X * 0.26) + 'px, ' + (dir * amp * 0.5) + 'px) rotate(' + (dir * -1.2) + 'deg)', offset: 0.4 },
              { transform: 'translate(' + (OFFSET_X * 0.56) + 'px, ' + (-dir * amp * 0.85) + 'px) rotate(' + (dir * 1.8) + 'deg)', opacity: 0.7, offset: 0.65 },
              { transform: 'translate(' + OFFSET_X + 'px, ' + (dir * amp * 0.6) + 'px) rotate(' + (dir * -2.2) + 'deg)', opacity: 0 }
            ],
            { duration: EXIT_MS, delay: exitDelay, easing: 'cubic-bezier(.5,0,.3,1)', fill: 'forwards' }
          );
          anim.finished.catch(() => {});
        });

        const lastFinish = EXIT_MS + EXIT_SPAN;
        setTimeout(() => { logoWrap.innerHTML = ''; }, lastFinish + 80);
      }

      document.addEventListener('astro:before-preparation', (event) => {
        const originalLoader = event.loader;
        event.loader = async () => {
          await playEnterPhase();
          await originalLoader();
        };
      });
      document.addEventListener('astro:after-swap', playExitPhase);
    }
    initPageTransition();
  </script>
</body>
</html>
