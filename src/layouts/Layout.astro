---
import { ViewTransitions } from 'astro:transitions';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  lang?: string;
}
const {
  title = 'Tecno Consult Srl — Agenzia di rappresentanza dal 1996',
  description = 'Idro-termo-sanitario, condizionamento ed energie alternative. Supporto tecnico e commerciale per grossisti, installatori e progettisti in Veneto e Friuli Venezia Giulia.',
  lang = 'it',
} = Astro.props;

const canonical = Astro.site
  ? new URL(Astro.url.pathname, Astro.site).href
  : Astro.url.href;
---
<!doctype html>
<html lang={lang}>
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="description" content={description} />
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;700&family=IBM+Plex+Sans:wght@400;500;600&family=IBM+Plex+Mono:wght@500;600&display=swap" rel="stylesheet">
<title>{title}</title>
<link rel="canonical" href={canonical} />
<link rel="icon" type="image/png" href="/images/tecnoconsult-icon.png" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:type" content="website" />
<meta property="og:url" content={canonical} />
<meta property="og:site_name" content="Tecno Consult Srl" />
<meta property="og:locale" content="it_IT" />
<meta property="og:image" content="https://tecnoconsult-srl.it/images/tecnoconsult-logo.png" />
<meta property="og:image:width" content="512" />
<meta property="og:image:height" content="512" />
<meta name="twitter:card" content="summary" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<ViewTransitions />
<style is:global>
  :root{
    --paper:#eef2f1;
    --surface:#ffffff;
    --tint:#dee6e6;
    --ink:#16242a;
    --ink-soft:#46565c;
    --petrol:#2d5563;
    --petrol-deep:#1c3a45;
    --copper:#c1632b;
    --line:#bcccc9;
    --line-soft:#d8e1df;
    --radius:10px;
    --maxw:1180px;
  }
  *{box-sizing:border-box;}
  html{scroll-behavior:smooth;}
  body{
    margin:0;
    overflow-x:hidden;
    background:var(--paper);
    color:var(--ink);
    font-family:'IBM Plex Sans',sans-serif;
    -webkit-font-smoothing:antialiased;
  }
  a{color:inherit;}
  .wrap{max-width:var(--maxw); margin:0 auto; padding:0 28px;}
  h1,h2,h3{font-family:'Space Grotesk',sans-serif; margin:0; letter-spacing:-0.01em;}
  p{margin:0;}
  :focus-visible{outline:2px solid var(--copper); outline-offset:3px;}

  .eyebrow{
    font-family:'IBM Plex Mono',monospace;
    font-size:0.78rem;
    letter-spacing:0.12em;
    text-transform:uppercase;
    color:var(--petrol);
    font-weight:600;
    display:inline-flex;
    align-items:center;
    gap:10px;
  }
  /* indicatore tecnico copper prima dell'etichetta */
  .eyebrow::before{
    content:"";
    width:18px;
    height:2px;
    background:var(--copper);
    flex-shrink:0;
  }
  /* sezioni principali numerate: 01 / 02 / 03 in copper, stile scheda tecnica */
  body{counter-reset:sect;}
  .section-head{counter-increment:sect;}
  .section-head .eyebrow::before{
    content:counter(sect,decimal-leading-zero);
    width:auto;
    height:auto;
    background:none;
    color:var(--copper);
    font-weight:700;
    letter-spacing:0.05em;
  }

  /* ---------- reveal ---------- */
  .reveal{opacity:0; transform:translateY(16px); transition:opacity .6s ease, transform .6s ease;}
  .reveal.is-visible{opacity:1; transform:none;}
  @media (prefers-reduced-motion:reduce){
    .reveal{opacity:1; transform:none; transition:none;}
  }

  /* ---------- nav ---------- */
  header{
    position:sticky; top:0; z-index:50;
    background:rgba(238,242,241,0.92);
    backdrop-filter:blur(6px);
    border-bottom:1px solid var(--line-soft);
  }
  .nav{display:flex; align-items:center; justify-content:space-between; padding:16px 28px; max-width:var(--maxw); margin:0 auto;}
  .brand{display:flex; align-items:center; gap:10px; text-decoration:none;}
  .brand img{height:30px; width:auto; display:block;}
  .brand-word{font-family:'Space Grotesk',sans-serif; font-weight:700; font-size:1.02rem; color:var(--ink); letter-spacing:-0.01em;}
  .brand-word span{color:var(--petrol);}
  .nav-links{display:flex; gap:26px; list-style:none; margin:0; padding:0;}
  .nav-links a{font-size:0.86rem; text-decoration:none; color:var(--ink-soft); font-weight:500;}
  .nav-links a:hover{color:var(--petrol);}
  .nav-links a[aria-current="page"]{color:var(--petrol); font-weight:600;}
  .nav-tel{
    font-family:'IBM Plex Mono',monospace;
    font-size:0.82rem;
    border:1px solid var(--petrol);
    color:var(--petrol);
    padding:7px 14px;
    border-radius:999px;
    text-decoration:none;
    white-space:nowrap;
  }
  .nav-tel:hover{background:var(--petrol); color:#fff;}
  .nav-tel-mobile{display:none;}
  .nav-toggle-input{display:none;}
  .nav-toggle{
    display:none;
    flex-direction:column;
    justify-content:center;
    align-items:center;
    gap:5px;
    width:44px;
    height:44px;
    cursor:pointer;
    flex-shrink:0;
  }
  .nav-toggle span{width:24px;}
  .nav-toggle span{display:block; width:100%; height:2px; background:var(--ink); border-radius:2px; transition:transform .25s ease, opacity .25s ease;}
  .nav-toggle-input:checked ~ .nav-toggle span:nth-child(1){transform:translateY(7px) rotate(45deg);}
  .nav-toggle-input:checked ~ .nav-toggle span:nth-child(2){opacity:0;}
  .nav-toggle-input:checked ~ .nav-toggle span:nth-child(3){transform:translateY(-7px) rotate(-45deg);}

  /* ---------- hero ---------- */
  .hero{
    position:relative;
    overflow:hidden;
    padding:64px 0 0;
    background-image:
      linear-gradient(rgba(238,242,241,0.94),rgba(238,242,241,0.94)),
      repeating-linear-gradient(0deg, rgba(45,85,99,0.07) 0 1px, transparent 1px 28px),
      repeating-linear-gradient(90deg, rgba(45,85,99,0.07) 0 1px, transparent 1px 28px);
  }
  .hero-grid{
    display:grid;
    grid-template-columns:1.1fr 1fr;
    gap:40px;
    align-items:center;
    padding-bottom:46px;
  }
  .hero h1{font-size:2.7rem; line-height:1.08; margin:14px 0 16px; color:var(--ink);}
  .hero p.lead{font-size:1.04rem; color:var(--ink-soft); max-width:460px; line-height:1.6; margin-bottom:26px;}
  .cta-row{display:flex; gap:14px; flex-wrap:wrap;}
  .btn{
    font-family:'IBM Plex Sans',sans-serif;
    font-weight:600;
    font-size:0.92rem;
    padding:13px 22px;
    border-radius:6px;
    text-decoration:none;
    display:inline-flex;
    align-items:center;
    gap:8px;
  }
  .btn-primary{background:var(--petrol); color:#fff;}
  .btn-primary:hover{background:var(--petrol-deep);}
  .btn-ghost{border:1px solid var(--line); color:var(--ink);}
  .btn-ghost:hover{border-color:var(--petrol); color:var(--petrol);}

  .hero-art{display:flex; justify-content:center;}
  .hero-logo-stage{
    position:relative;
    display:flex;
    align-items:center;
    justify-content:center;
    width:100%;
    max-width:420px;
    aspect-ratio:1;
  }
  .hero-logo-halo{
    position:absolute;
    inset:0;
    border-radius:50%;
    background:radial-gradient(closest-side, rgba(193,99,43,0.16), rgba(45,85,99,0.14) 55%, transparent 75%);
    filter:blur(18px);
  }
  .hero-logo{
    position:relative;
    width:62%;
    max-width:280px;
    height:auto;
    animation:logoScaleIn .9s ease-out both, logoBreathe 6s ease-in-out 0.9s infinite;
  }
  @keyframes logoScaleIn{ from{opacity:0; transform:scale(0.92);} to{opacity:1; transform:scale(1);} }
  @keyframes logoBreathe{ 0%,100%{transform:scale(1);} 50%{transform:scale(1.02);} }
  @media (prefers-reduced-motion:reduce){
    .hero-logo{animation:none;}
  }

  .sr-only{
    position:absolute; width:1px; height:1px; padding:0; margin:-1px;
    overflow:hidden; clip:rect(0,0,0,0); white-space:nowrap; border:0;
  }

  /* ---------- datasheet strip ---------- */
  .datasheet{
    border-top:2px solid var(--petrol);
    border-bottom:1px solid var(--line);
    background:var(--surface);
  }
  .datasheet .wrap{
    display:grid;
    grid-template-columns:repeat(4,1fr);
  }
  .ds-item{
    padding:22px 24px;
    border-right:1px solid var(--line-soft);
  }
  .ds-item:last-child{border-right:none;}
  .ds-key{font-family:'IBM Plex Mono',monospace; font-size:0.68rem; letter-spacing:0.1em; color:var(--ink-soft); text-transform:uppercase;}
  .ds-val{font-family:'IBM Plex Mono',monospace; font-size:1.5rem; font-weight:600; color:var(--petrol); margin-top:4px;}

  /* ---------- pipe divider ---------- */
  .pipe-divider{display:block; width:100%; height:34px;}

  section{padding:70px 0;}
  .section-head{margin-bottom:44px; max-width:680px;}
  .section-head h2{font-size:clamp(1.8rem,3.2vw,2.6rem); line-height:1.1; letter-spacing:-0.02em; margin-top:12px;}
  .section-head p{color:var(--ink-soft); margin-top:12px; line-height:1.6;}

  /* ---------- chi siamo ---------- */
  .chisiamo{
    display:grid;
    grid-template-columns:1.4fr 0.9fr;
    gap:48px;
    align-items:center;
  }
  .chisiamo p{font-size:1rem; line-height:1.7; color:var(--ink);}
  .chisiamo p + p{margin-top:14px;}
  .founder-card{
    border:1px solid var(--line);
    border-radius:var(--radius);
    background:var(--surface);
    padding:20px 22px;
  }
  .founder-card .ds-key{margin-bottom:6px;}
  .founder-card .founder-name{font-family:'Space Grotesk',sans-serif; font-weight:700; font-size:1.1rem;}
  .founder-card .founder-role{font-size:0.86rem; color:var(--ink-soft); margin-top:2px;}

  /* ---------- team ---------- */
  .team-grid{
    display:grid;
    grid-template-columns:repeat(5,1fr);
    gap:18px;
    margin-top:14px;
  }
  .team-card{
    background:var(--surface);
    border:1px solid var(--line-soft);
    border-radius:var(--radius);
    padding:16px;
    text-align:left;
  }
  .avatar{
    width:100%;
    aspect-ratio:1;
    border:1.5px dashed var(--line);
    border-radius:8px;
    display:flex;
    align-items:center;
    justify-content:center;
    font-family:'IBM Plex Mono',monospace;
    font-size:1.3rem;
    color:var(--ink-soft);
    background:repeating-linear-gradient(45deg, rgba(45,85,99,0.04) 0 8px, transparent 8px 16px);
    margin-bottom:12px;
  }
  .team-card--empty{display:flex; flex-direction:column; justify-content:flex-start;}
  .avatar--empty{color:var(--line);}
  .team-card--empty .team-role{color:var(--ink-soft); font-style:italic;}
  .team-name{font-weight:600; font-size:0.94rem;}
  .team-role{font-size:0.78rem; color:var(--ink-soft); margin-top:3px; line-height:1.4;}
  .team-contact{font-family:'IBM Plex Mono',monospace; font-size:0.68rem; color:var(--petrol); margin-top:8px; word-break:break-word; display:block; text-decoration:none;}
  .photo-note{font-size:0.72rem; color:var(--ink-soft); margin-top:14px; font-style:italic;}

  /* ---------- marquee ---------- */
  .marquee-section{background:var(--surface); border-top:1px solid var(--line); border-bottom:1px solid var(--line); padding:42px 0;}
  .marquee-label{font-family:'IBM Plex Mono',monospace; font-size:0.7rem; letter-spacing:0.12em; text-transform:uppercase; color:var(--ink-soft); margin-bottom:18px; display:block;}
  .marquee-label-affida{
    text-align:center;
    color:var(--copper);
    font-weight:700;
    font-family:'Space Grotesk',sans-serif;
    font-size:1.1rem;
    letter-spacing:-0.01em;
    text-transform:none;
    margin-bottom:28px;
  }
  .marquee{overflow:hidden; position:relative; mask-image:linear-gradient(90deg, transparent, #000 6%, #000 94%, transparent);}
  .marquee-track{display:flex; gap:18px; width:max-content; animation:scrollLeft 32s linear infinite; will-change:transform; backface-visibility:hidden;}
  .marquee:hover .marquee-track{animation-play-state:paused;}
  @keyframes scrollLeft{ from{transform:translateX(0);} to{transform:translateX(-50%);} }
  @media (prefers-reduced-motion:reduce){ .marquee-track{animation:none;} .marquee{overflow-x:auto;} }

  .brand-chip{
    border:1px solid var(--line);
    border-radius:6px;
    padding:14px 22px;
    font-family:'Space Grotesk',sans-serif;
    font-weight:700;
    font-size:1rem;
    color:var(--ink);
    background:var(--paper);
    white-space:nowrap;
  }
  /* ---------- griglia marchi rappresentati (home) ---------- */
  .brand-logo-grid {
    margin-top: 22px;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }
  .brand-logo-tile {
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--surface);
    padding: 22px;
    display: flex;
    align-items: center;
    justify-content: center;
    height: 96px;
    transition: transform .2s ease, box-shadow .2s ease, border-color .2s ease;
  }
  .brand-logo-tile img {
    max-height: 46px;
    max-width: 130px;
    width: auto;
    height: auto;
    object-fit: contain;
  }
  .brand-logo-tile:hover {
    transform: scale(1.03);
    border-color: var(--copper);
    box-shadow: 0 4px 18px rgba(193,99,43,0.14);
  }
  @media (max-width: 640px) {
    .brand-logo-grid { grid-template-columns: repeat(2, 1fr); }
  }

  .maps-embed { border-radius: var(--radius); overflow: hidden; border: 1px solid var(--line-soft); }

  .brand-territory-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    margin-top: 28px;
  }
  .bt-card {
    display: flex;
    align-items: center;
    gap: 16px;
    background: var(--surface);
    border: 1px solid var(--line-soft);
    border-radius: var(--radius);
    padding: 16px 18px;
    text-decoration: none;
    color: inherit;
    cursor: pointer;
  }
  .bt-logo {
    flex-shrink: 0;
    width: 80px;
    height: 50px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .bt-logo img {
    max-width: 80px;
    max-height: 40px;
    object-fit: contain;
    width: auto;
    height: auto;
  }
  .bt-name {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 600;
    font-size: 0.88rem;
    color: var(--ink);
  }
  .bt-zone {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.68rem;
    color: var(--petrol);
    letter-spacing: 0.04em;
    margin-top: 4px;
    line-height: 1.4;
  }
  @media (max-width: 920px) {
    .brand-territory-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 560px) {
    .brand-territory-grid { grid-template-columns: 1fr; }
  }
  .brand-note{font-size:0.78rem; color:var(--ink-soft); margin-top:16px;}

  /* ---------- mappa di copertura interattiva (dove operiamo) ---------- */
  #mappa-copertura{scroll-margin-top:90px;}
  .coverage-map-wrap{
    position:relative;
    max-width:560px;
    margin:0 auto;
  }
  .coverage-map{display:block; width:100%; height:auto;}
  .coverage-tooltip{
    position:absolute;
    top:0; left:0;
    z-index:30;
    min-width:150px;
    max-width:210px;
    background:var(--ink);
    color:#fff;
    border-radius:8px;
    padding:12px 14px;
    box-shadow:0 8px 24px rgba(0,0,0,0.2);
    pointer-events:none;
  }
  .coverage-tooltip[hidden]{display:none;}
  .ct-title{
    font-family:'Space Grotesk',sans-serif;
    font-weight:700;
    font-size:0.86rem;
    margin-bottom:8px;
  }
  .ct-brands{display:flex; flex-direction:column; gap:8px;}
  .ct-brands.ct-empty{color:#c7d0d2; font-style:italic; font-size:0.76rem;}
  .ct-brand{display:flex; align-items:center; gap:8px;}
  .ct-brand img{width:24px; height:24px; object-fit:contain; background:#fff; border-radius:4px; padding:2px;}
  .ct-brand span{font-family:'IBM Plex Mono',monospace; font-size:0.68rem; letter-spacing:0.02em;}

  .ref-chip{
    font-family:'IBM Plex Mono',monospace;
    font-size:0.84rem;
    color:var(--ink-soft);
    white-space:nowrap;
    display:flex;
    align-items:center;
    gap:18px;
  }
  .ref-chip::after{content:"·"; color:var(--copper);}
  .ref-chip:last-child::after{content:none;}

  /* etichetta categoria fissa a sinistra di ogni riga referenze */
  .ref-row{display:flex; align-items:center; gap:24px; max-width:var(--maxw); margin:0 auto; padding:0 28px;}
  .ref-row + .ref-row{margin-top:16px;}
  .ref-cat{
    flex:0 0 200px;
    font-family:'IBM Plex Mono',monospace;
    font-size:0.72rem;
    letter-spacing:0.08em;
    text-transform:uppercase;
    color:var(--petrol);
    border-right:1px solid var(--line);
    padding-right:18px;
    white-space:nowrap;
  }
  .ref-row .marquee{flex:1; min-width:0;}

  /* ---------- dove operiamo ---------- */
  .dove{
    display:grid;
    grid-template-columns:1fr 0.85fr;
    gap:48px;
    align-items:center;
  }
  /* ---------- servizi ---------- */
  .servizi-grid{
    display:grid;
    grid-template-columns:repeat(4,1fr);
    gap:16px;
    margin-top:30px;
  }
  .servizio-card{
    background:var(--surface);
    border:1px solid var(--line-soft);
    border-radius:var(--radius);
    padding:22px 20px;
  }
  .servizio-card svg{margin-bottom:14px;}
  .servizio-card h3{font-size:1.14rem; font-weight:600; color:var(--ink); margin-bottom:8px;}
  .servizio-card p{font-size:0.84rem; color:var(--ink-soft); line-height:1.55;}

  /* ---------- anteprima mappa di copertura (home) ---------- */
  .coverage-preview-card{
    display:block;
    background:var(--surface);
    border:1px solid var(--line-soft);
    border-radius:var(--radius);
    overflow:hidden;
    max-width:480px;
    margin:0 auto;
    cursor:pointer;
    transition:filter .2s ease, transform .2s ease;
  }
  .coverage-preview-card img{display:block; width:100%; height:auto;}
  .coverage-preview-card:hover{filter:brightness(1.04); transform:scale(1.01);}

  /* ---------- mission / vision ---------- */
  .mission-statement{font-size:1.18rem; line-height:1.6; max-width:760px; color:var(--ink);}
  .mv-full-toggle{margin-top:18px;}
  .mv-full-toggle > summary{
    cursor:pointer;
    list-style:none;
    font-family:'IBM Plex Mono',monospace;
    font-size:0.72rem;
    letter-spacing:0.06em;
    text-transform:uppercase;
    color:var(--petrol);
    display:inline-flex;
    align-items:center;
    gap:6px;
    user-select:none;
  }
  .mv-full-toggle > summary::-webkit-details-marker{display:none;}
  .mv-full-toggle > summary::before{content:"▸"; transition:transform .2s;}
  .mv-full-toggle[open] > summary::before{transform:rotate(90deg);}
  .mv-full-text{margin-top:16px; max-width:760px;}
  .mv-full-text p{font-size:0.95rem; line-height:1.75; color:var(--ink-soft); margin-top:14px;}
  .mv-full-text p:first-child{margin-top:0;}

  /* ---------- mission & vision preview (home) ---------- */
  .mv-preview-grid{display:grid; grid-template-columns:1fr 1fr; gap:20px; margin-top:30px;}
  .mv-preview-card{background:var(--surface); border:1px solid var(--line-soft); border-radius:var(--radius); padding:26px 24px;}
  .mv-preview-card .ds-key{margin-bottom:10px;}
  .mv-preview-text{font-size:0.92rem; line-height:1.65; color:var(--ink); margin-bottom:14px;}
  @media (max-width:720px){
    .mv-preview-grid{grid-template-columns:1fr;}
  }

  .pillars{
    display:grid;
    grid-template-columns:repeat(3,1fr);
    margin-top:38px;
  }
  .pillar{
    padding:0 26px;
    border-left:1px solid var(--line);
  }
  .pillar:first-child{border-left:none; padding-left:0;}
  .pillar h3{font-size:1.16rem; font-weight:600; margin-bottom:8px; color:var(--ink);}
  .pillar p{font-size:0.86rem; color:var(--ink-soft); line-height:1.55;}

  /* ---------- contatti ---------- */
  .contatti{
    background:var(--ink);
    color:#e9eef0;
    border-radius:16px;
    padding:48px 44px;
    display:grid;
    grid-template-columns:1.1fr 1fr;
    gap:40px;
    align-items:center;
  }
  .contatti h2{color:#fff;}
  .contatti p.lead{color:#aebcc0; margin-top:10px; max-width:420px; line-height:1.6;}
  .contact-list{margin-top:24px; display:grid; gap:12px;}
  .contact-list a, .contact-list span{font-family:'IBM Plex Mono',monospace; font-size:0.86rem; color:#dfe7e8; text-decoration:none;}
  .contact-list a:hover{color:var(--copper);}
  .contatti .btn-primary{background:var(--copper);}
  .contatti .btn-primary:hover{background:#a4501f;}
  .hours{font-size:0.78rem; color:#8fa0a5; margin-top:18px; line-height:1.5;}

  /* ---------- footer ---------- */
