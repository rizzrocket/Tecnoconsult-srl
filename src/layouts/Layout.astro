  <script>
    function initReveal() {
      const els = Array.from(document.querySelectorAll('.reveal'));
      if (!els.length) return;
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        els.forEach((el) => el.classList.add('is-visible'));
        return;
      }
      const obs = new IntersectionObserver((entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add('is-visible');
            obs.unobserve(e.target);
          }
        });
      }, { threshold: 0.15 });
      els.forEach((el) => obs.observe(el));
    }
    document.addEventListener('astro:page-load', initReveal);

    function initPipeDividers() {
      const paths = Array.from(document.querySelectorAll<SVGPathElement>('.pipe-divider path'));
      if (!paths.length) return;
      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      paths.forEach((path) => {
        const length = path.getTotalLength();
        path.style.strokeDasharray = String(length);
        path.style.strokeDashoffset = reduceMotion ? '0' : String(length);
      });
      if (reduceMotion) return;

      const obs = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const path = entry.target as SVGPathElement;
            path.style.transition = 'stroke-dashoffset 700ms ease-in-out';
            path.style.strokeDashoffset = '0';
            obs.unobserve(path);
          }
        });
      }, { threshold: 0.3 });
      paths.forEach((path) => obs.observe(path));
    }
    document.addEventListener('astro:page-load', initPipeDividers);

    function initPageTransition() {
      const overlay = document.getElementById('tc-transition');
      const veil = document.getElementById('tc-veil');
      const svg = document.getElementById('tc-transition-svg');
      const logoWrap = document.getElementById('tc-logo-lines');
      if (!overlay || !svg || overlay.dataset.tcInit) return;
      overlay.dataset.tcInit = '1';

      // Geometria del logo reale ricalibrata con misurazione MANUALE su griglia
      // di coordinate sovrapposta a public/images/tecnoconsult-icon.png (318x302)
      // e verificata renderizzando le linee accanto al logo vero: combacia.
      // Cerchio: centro (151.5, 150), raggio centro-linea r=116; l'apertura
      // della C è una piccola tacca a ore 4-5 (da 45° a 387°=27°, angoli SVG
      // y-verso-il-basso), NON un varco enorme a ore 3. Barra T: y=63,
      // x 20..280. Gambo: x=151.5, da y=78 a y=260.
      // Ogni pezzo è una LINEA singola (filo), non una forma chiusa.
      // NON rimisurare: valori verificati visivamente il 2026-07-08.
      const CANVAS_W = 302, CANVAS_H = 302;
      const LINES = [
        { type: 'arc',  cx: 151.5, cy: 150, r: 116, a0: 45, a1: 387, x0: 35.5 },
        { type: 'line', x1: 20,    y1: 63,  x2: 280, y2: 63,           x0: 20 },
        { type: 'line', x1: 151.5, y1: 78,  x2: 151.5, y2: 260,        x0: 151.5 }
      ];

      const ENTER_MS = 700, ENTER_SPAN = 260;
      const HOLD_MS = 260;
      const EXIT_MS = 700, EXIT_SPAN = 260;

      function reduceMotion() { return window.matchMedia('(prefers-reduced-motion: reduce)').matches; }

      function buildPaths(W, H) {
        const size = Math.min(W, H) * 0.5;
        const scale = size / CANVAS_W;
        const offX = W / 2 - (CANVAS_W * scale) / 2;
        const offY = H / 2 - (CANVAS_H * scale) / 2;
        const tx = (x) => offX + x * scale;
        const ty = (y) => offY + y * scale;

        return LINES.map((s) => {
          let d;
          if (s.type === 'arc') {
            // arco singolo aperto a raggio medio: una sola linea curva, non una fascia
            const r = s.r * scale;
            const cx = tx(s.cx), cy = ty(s.cy);
            const rad0 = (s.a0 * Math.PI) / 180, rad1 = (s.a1 * Math.PI) / 180;
            const span = ((s.a1 - s.a0) % 360 + 360) % 360;
            const largeArc = span > 180 ? 1 : 0;
            const p0 = [cx + r * Math.cos(rad0), cy + r * Math.sin(rad0)];
            const p1 = [cx + r * Math.cos(rad1), cy + r * Math.sin(rad1)];
            d = 'M' + p0[0] + ' ' + p0[1] +
              ' A' + r + ' ' + r + ' 0 ' + largeArc + ' 1 ' + p1[0] + ' ' + p1[1];
          } else {
            // segmento singolo (barra o gambo della T)
            d = 'M' + tx(s.x1) + ' ' + ty(s.y1) + ' L' + tx(s.x2) + ' ' + ty(s.y2);
          }
          return { d, x0: s.x0 };
        });
      }

      function playEnterPhase() {
        return new Promise((resolve) => {
          if (reduceMotion()) { resolve(); return; }

          const W = window.innerWidth, H = window.innerHeight;
          svg.setAttribute('viewBox', '0 0 ' + W + ' ' + H);
          logoWrap.innerHTML = '';
          veil.style.transition = 'none';
          veil.style.opacity = '0';
          void svg.getBoundingClientRect();

          const paths = buildPaths(W, H);
          const xs = paths.map((p) => p.x0);
          const minX = Math.min.apply(null, xs), maxX = Math.max.apply(null, xs);
          const span = Math.max(1, maxX - minX);
          const OFFSET_X = W * 0.55;

          const els = [];
          const AMP = Math.max(14, H * 0.03); // ampiezza dell'ondulazione "a serpente" (~3vh)
          const AMP_VAR = [1, 0.75, 0.9]; // arco pieno, barra lunga più contenuta, gambo medio
          paths.forEach((pdata, i) => {
            const el = document.createElementNS('http://www.w3.org/2000/svg', 'path');
            el.setAttribute('d', pdata.d);
            logoWrap.appendChild(el);
            const delay = ((pdata.x0 - minX) / span) * ENTER_SPAN;
            const dir = i % 2 === 0 ? 1 : -1; // fase alternata: ogni filo ondeggia per conto suo
