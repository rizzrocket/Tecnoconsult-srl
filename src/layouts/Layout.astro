  <script>
    function initReveal() {
      const els = Array.from(document.querySelectorAll('.reveal'));
      if (!els.length) return;
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        els.forEach((el) => el.classList.add('is-visible'));
        return;
      }
      const obs = new IntersectionObserver((entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add('is-visible');
            obs.unobserve(e.target);
          }
        });
      }, { threshold: 0.15 });
      els.forEach((el) => obs.observe(el));
    }
    document.addEventListener('astro:page-load', initReveal);

    function initPipeDividers() {
      const paths = Array.from(document.querySelectorAll<SVGPathElement>('.pipe-divider path'));
      if (!paths.length) return;
      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      paths.forEach((path) => {
        const length = path.getTotalLength();
        path.style.strokeDasharray = String(length);
        path.style.strokeDashoffset = reduceMotion ? '0' : String(length);
      });
      if (reduceMotion) return;

      const obs = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const path = entry.target as SVGPathElement;
            path.style.transition = 'stroke-dashoffset 700ms ease-in-out';
            path.style.strokeDashoffset = '0';
            obs.unobserve(path);
          }
        });
      }, { threshold: 0.3 });
      paths.forEach((path) => obs.observe(path));
    }
    document.addEventListener('astro:page-load', initPipeDividers);

    function startPageWipe() {
      const el = document.getElementById('page-wipe');
      if (!el) return;
      el.classList.remove('is-animating');
      void el.offsetWidth;
      el.classList.add('is-animating');
    }
    function endPageWipe() {
      const el = document.getElementById('page-wipe');
      if (!el) return;
      el.classList.remove('is-animating');
    }
    document.addEventListener('astro:before-preparation', startPageWipe);
    document.addEventListener('astro:page-load', endPageWipe);
  </script>
